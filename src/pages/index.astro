---
import Layout from '../layouts/Layout.astro';

// .env / GitHub Secrets から読み込み
const apiKey = import.meta.env.NOTION_API_KEY;
const blogDbId = import.meta.env.NOTION_BLOG_ID;
const glossaryDbId = import.meta.env.NOTION_GLOSSARY_ID; 
const quizDbId = import.meta.env.NOTION_QUIZ_ID;
const youtubeChannelId = import.meta.env.YOUTUBE_CHANNEL_ID || 'UC8FyvgMTWWN77utbwmtAX8w';

// プロパティを安全に取得する関数
function getPlainText(prop: any) {
    if (!prop) return "";
    if (prop.title && prop.title.length > 0) return prop.title[0]?.plain_text || "";
    if (prop.rich_text && prop.rich_text.length > 0) return prop.rich_text[0]?.plain_text || "";
    if (prop.number !== undefined && prop.number !== null) return String(prop.number);
    return "";
}

async function fetchNotionData(databaseId: string) {
  if (!databaseId) return [];
  try {
    const res = await fetch(`https://api.notion.com/v1/databases/${databaseId}/query`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${apiKey}`,
        'Notion-Version': '2022-06-28',
        'Content-Type': 'application/json',
      }
    });
    const data = await res.json();
    return data.results || [];
  } catch (err) {
    console.error(`Notion API 通信エラー (${databaseId})`, err);
    return [];
  }
}

// 1. ブログ
const allPosts = await fetchNotionData(blogDbId);
const recentPosts = allPosts
  .filter((post: any) => {
    const status = post.properties['ステータス']?.status?.name || post.properties['ステータス']?.select?.name || '';
    return status === '公開';
  })
  .sort((a: any, b: any) => {
    // 🌟 日付を取得して新しい順（降順）に並び替える処理を追加
    const dateA = new Date(a.properties['日付']?.date?.start || 0).getTime();
    const dateB = new Date(b.properties['日付']?.date?.start || 0).getTime();
    return dateB - dateA;
  })
  .slice(0, 3);

// 2. 用語集
const allGlossary = await fetchNotionData(glossaryDbId);
const randomGlossary = allGlossary.sort(() => 0.5 - Math.random()).slice(0, 2);

// 3. クイズ（ホーム画面用に選択肢や解説もすべて取得）
const allQuiz = await fetchNotionData(quizDbId);
const randomQuiz = allQuiz.sort(() => 0.5 - Math.random()).slice(0, 1);

let hqQuestion = "";
let hqChoices: string[] = [];
let hqCorrect = "";
let hqExplanation = "";

if (randomQuiz.length > 0) {
    const q = randomQuiz[0];
    hqQuestion = getPlainText(q.properties['問題文'] || q.properties['タイトル']);
    const c1 = getPlainText(q.properties['選択肢1']);
    const c2 = getPlainText(q.properties['選択肢2']);
    const c3 = getPlainText(q.properties['選択肢3']);
    const c4 = getPlainText(q.properties['選択肢4']);
    hqChoices = [c1, c2, c3, c4].filter(c => c !== "");
    hqCorrect = getPlainText(q.properties['正解の番号'] || q.properties['正解']);
    hqExplanation = getPlainText(q.properties['解説']);
}

// 4. YouTube最新動画
let latestVideos = [];
try {
  if (youtubeChannelId && youtubeChannelId.startsWith('UC')) {
    const rssUrl = `https://www.youtube.com/feeds/videos.xml?channel_id=${youtubeChannelId}`;
    const ytRes = await fetch(`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(rssUrl)}`);
    const ytData = await ytRes.json();
    if (ytData.status === 'ok') {
      latestVideos = ytData.items.filter((item: any) => !item.link.includes('utx7ktMEzPE')).slice(0, 2);
    }
  }
} catch (error) {
  console.error('YouTube最新動画エラー:', error);
}

const mainVideo = {
    id: "utx7ktMEzPE",
    title: "「時期」までピタリと当てる。プロの分析術『流年法』と悩みに向き合う応用方法【手相体験講座】"
};
---

<Layout title="手相のマヨネリ | 根本解決の手相鑑定・自己分析ツール">
    
    <section class="hero-container">
        <div class="hero-content text-center">
            <h1 class="hero-title">手相は最強の<br>「自己分析ツール」である。</h1>
            <p class="hero-desc">運命を「当てる」のではなく、仕組みを「論理的」に紐解く。<br>迷信を排除した、根本解決のための手相学。</p>
            <div class="hero-actions">
                <a href="/shindan" class="btn-primary pulse-animation">
                    <span class="btn-icon">✋</span> 無料手相・性格診断を試す
                </a>
            </div>
        </div>
    </section>

    <div class="container main-content">
        
        <section class="top-section youtube-section">
            <div class="section-header">
                <h2 class="section-title">動画で学ぶ「論理的手相学」</h2>
                <a href="https://www.youtube.com/@mayotesoh" target="_blank" rel="noopener noreferrer" class="view-all">チャンネル登録 →</a>
            </div>
            
            <div class="youtube-grid">
                <div class="yt-main">
                    <h3 class="yt-label">おすすめ動画</h3>
                    <div class="yt-item-card main-video-card">
                        <div class="iframe-wrapper">
                            <iframe src={`https://www.youtube.com/embed/${mainVideo.id}`} title="YouTube video player" frameborder="0" allowfullscreen></iframe>
                        </div>
                        <div class="yt-info">
                            <span class="yt-title" title={mainVideo.title}>{mainVideo.title}</span>
                        </div>
                    </div>
                </div>
                
                <div class="yt-sub">
                    <h3 class="yt-label">最新の動画</h3>
                    {latestVideos.length > 0 ? (
                        <div class="yt-sub-list">
                            {latestVideos.map((video: any) => {
                                let videoId = '';
                                if (video.link.includes('v=')) {
                                    videoId = video.link.split('v=')[1].split('&')[0];
                                } else if (video.link.includes('shorts/')) {
                                    videoId = video.link.split('shorts/')[1].split('?')[0];
                                } else {
                                    videoId = video.link.split('/').pop();
                                }
                                
                                const isShort = video.link.includes('shorts/') || video.title.toLowerCase().includes('short') || video.title.includes('ショート');
                                const displayTitle = isShort && !video.title.includes('【ショート】') ? `【ショート】${video.title}` : video.title;

                                return videoId ? (
                                    <div class="yt-item-card">
                                        <div class="iframe-wrapper-small">
                                            <iframe src={`https://www.youtube.com/embed/${videoId}`} title="YouTube video player" frameborder="0" allowfullscreen></iframe>
                                        </div>
                                        <div class="yt-info">
                                            {isShort && <span class="yt-badge">Shorts</span>}
                                            <span class="yt-title" title={displayTitle}>{displayTitle}</span>
                                        </div>
                                    </div>
                                ) : null;
                            })}
                        </div>
                    ) : (
                        <div class="dummy-video-box">
                            <p>最新動画を読み込んでいます...</p>
                        </div>
                    )}
                </div>
            </div>
        </section>

        <section class="top-section">
            <div class="section-header">
                <h2 class="section-title">最新のブログ・思考録</h2>
                <a href="/blog" class="view-all">すべて見る →</a>
            </div>
            
            <div class="blog-grid">
                {recentPosts.length > 0 ? (
                    recentPosts.map((post: any) => {
                        const title = getPlainText(post.properties['タイトル'] || post.properties['Name']) || '無題';
                        const dateStr = post.properties['日付']?.date?.start || '';
                        const date = dateStr ? new Date(dateStr).toLocaleDateString('ja-JP') : '日付なし';
                        const categories = post.properties['カテゴリー']?.multi_select?.map((t: any) => t.name) || [];
                        const slug = getPlainText(post.properties['URLスラッグ']) || post.id;
                        
                        const eyecatchProp = post.properties['アイキャッチ'];
                        let eyecatchUrl = '/favicon.png'; 
                        
                        if (eyecatchProp) {
                            if (eyecatchProp.type === 'rich_text' && eyecatchProp.rich_text.length > 0) {
                                const textUrl = eyecatchProp.rich_text[0].plain_text.trim();
                                if (textUrl !== "") eyecatchUrl = textUrl;
                            } else if (eyecatchProp.type === 'files' && eyecatchProp.files.length > 0) {
                                eyecatchUrl = eyecatchProp.files[0].type === 'file' ? eyecatchProp.files[0].file.url : eyecatchProp.files[0].external?.url;
                            }
                        }
                        
                        return (
                            <a href={`/blog/${slug}`} class="blog-card-link">
                                <article class="blog-card">
                                    <div class="blog-card-img-wrapper">
                                        <img src={eyecatchUrl} alt={title} class="blog-card-img" loading="lazy" />
                                    </div>
                                    <div class="blog-card-content">
                                        <div class="blog-meta">
                                            <time class="blog-date">{date}</time>
                                            <div class="blog-tags">
                                                {categories.map((cat: string) => ( <span class="tag">#{cat}</span> ))}
                                            </div>
                                        </div>
                                        <h3 class="blog-title">{title}</h3>
                                    </div>
                                </article>
                            </a>
                        );
                    })
                ) : (
                    <p class="empty-text">記事を準備中です。</p>
                )}
            </div>
        </section>

        <section class="top-section dictionary-section">
            <div class="section-header">
                <h2 class="section-title">手相辞典 ＆ クイズ</h2>
                <div class="view-all-links">
                    <a href="/glossary" class="view-all">用語集一覧 →</a>
                    <a href="/quiz" class="view-all" style="margin-left: 15px;">クイズ一覧 →</a>
                </div>
            </div>
            
            <div class="dict-grid">
                
                {/* 用語集カード（左側・2件） */}
                <div class="glossary-column">
                    {randomGlossary.length > 0 ? (
                        randomGlossary.map((item: any) => {
                            const title = getPlainText(item.properties['名前'] || item.properties['タイトル']) || '無題の用語';
                            const summary = getPlainText(item.properties['意味'] || item.properties['概要']);
                            const slug = getPlainText(item.properties['URLスラッグ']) || item.id;
                            return (
                                <a href={`/glossary/${slug}`} class="dict-card glossary-card">
                                    <span class="card-badge">今日の用語</span>
                                    <h3 class="dict-title">{title}</h3>
                                    <p class="dict-summary">{summary}</p>
                                </a>
                            )
                        })
                    ) : (
                        <div class="empty-text">用語集を準備中です。</div>
                    )}
                </div>
                
                {/* ホーム画面直接完結型 クイズカード（右側・1件） */}
                <div class="quiz-column">
                    {randomQuiz.length > 0 ? (
                        <div class="dict-card quiz-interactive-card" id="home-quiz-container" data-correct={hqCorrect}>
                            <span class="card-badge quiz-badge">今日のミニクイズに挑戦！</span>
                            <h3 class="dict-title quiz-q-text">Q. {hqQuestion}</h3>
                            
                            <div class="home-choices">
                                {hqChoices.map((choice, index) => (
                                    <button class="home-choice-btn" data-number={index + 1}>
                                        <span class="choice-number">{index + 1}</span>
                                        <span class="choice-text">{choice}</span>
                                    </button>
                                ))}
                            </div>
                            
                            <div class="action-area">
                                <button id="home-quiz-submit" class="btn-primary-small" disabled>答え合わせをする</button>
                            </div>

                            <div id="home-quiz-result" class="home-result-box" style="display: none;">
                                <div class="result-header">
                                    <span id="home-result-mark" class="result-mark"></span>
                                    <h4 class="result-title">正解は「{hqCorrect}」</h4>
                                </div>
                                <div class="explanation-content">
                                    <p>{hqExplanation || '解説は準備中です。'}</p>
                                </div>
                                <div class="more-quiz-action">
                                    <a href="/quiz" class="btn-more-quiz">他のクイズも解いてみる →</a>
                                </div>
                            </div>
                        </div>
                    ) : (
                        <div class="empty-text">クイズを準備中です。</div>
                    )}
                </div>

            </div>
        </section>

    </div>
</Layout>

<style>
    .hero-container { background: linear-gradient(135deg, var(--color-primary), #2c4a3d); color: white; padding: 100px 15px; margin-bottom: 60px; }
    .hero-content { max-width: 800px; margin: 0 auto; }
    .hero-title { font-size: 3rem; line-height: 1.3; margin-bottom: 25px; letter-spacing: 0.05em; text-shadow: 0 2px 10px rgba(0,0,0,0.2); }
    .hero-desc { font-size: 1.2rem; line-height: 1.8; margin-bottom: 40px; opacity: 0.9; }
    .hero-actions { display: flex; justify-content: center; }
    .btn-primary { display: inline-block; background-color: white; color: var(--color-primary); padding: 18px 40px; font-size: 1.3rem; font-weight: bold; border-radius: 40px; text-decoration: none; box-shadow: 0 10px 25px rgba(0,0,0,0.2); transition: transform 0.2s; }
    .btn-primary:hover { transform: translateY(-3px); }
    .btn-icon { margin-right: 8px; font-size: 1.4rem; }

    .pulse-animation { animation: pulse 2s infinite; }
    @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.4); } 70% { box-shadow: 0 0 0 15px rgba(255, 255, 255, 0); } 100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); } }

    .main-content { padding-bottom: 60px; }
    .top-section { margin-bottom: 80px; }
    .section-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px; border-bottom: 2px solid var(--color-bg); padding-bottom: 10px; }
    .section-title { color: var(--color-primary); font-size: 1.8rem; margin: 0; }
    .view-all { color: var(--color-accent); font-weight: bold; text-decoration: none; transition: opacity 0.2s; }
    .view-all:hover { opacity: 0.7; }
    .view-all-links { display: flex; align-items: center; }

    .youtube-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 30px; }
    .yt-label { font-size: 1.1rem; color: var(--color-primary); margin-bottom: 15px; display: flex; align-items: center; gap: 8px; font-weight: bold; }
    .yt-label::before { content: "▶"; color: #ff0000; font-size: 1.2rem; }
    .yt-item-card { display: flex; flex-direction: column; gap: 8px; }
    .main-video-card { gap: 12px; }
    .iframe-wrapper { position: relative; width: 100%; padding-bottom: 56.25%; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.1); background: #000; }
    .iframe-wrapper iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
    .yt-sub-list { display: flex; flex-direction: column; gap: 20px; }
    .iframe-wrapper-small { position: relative; width: 100%; padding-bottom: 56.25%; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1); background: #000; }
    .iframe-wrapper-small iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
    .yt-info { display: flex; align-items: flex-start; gap: 8px; font-size: 0.85rem; color: var(--color-text); line-height: 1.4; }
    .main-video-card .yt-info { font-size: 1rem; } 
    .yt-badge { background-color: #ff0000; color: white; padding: 2px 6px; border-radius: 4px; font-size: 0.7rem; font-weight: bold; flex-shrink: 0; margin-top: 2px; }
    .yt-title { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; font-weight: bold; }
    .dummy-video-box { background: #f9f9f9; border: 1px dashed #ccc; border-radius: 8px; padding: 30px 15px; text-align: center; color: #888; height: 100%; display: flex; flex-direction: column; justify-content: center; }

    .blog-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px; }
    .blog-card-link { text-decoration: none; color: inherit; display: block; }
    .blog-card { background: white; border-radius: 12px; border: 1px solid #e1ebe5; box-shadow: 0 4px 10px rgba(0,0,0,0.03); transition: transform 0.2s, box-shadow 0.2s; height: 100%; display: flex; flex-direction: column; overflow: hidden; }
    .blog-card-link:hover .blog-card { transform: translateY(-5px); box-shadow: 0 8px 20px rgba(78, 123, 103, 0.1); border-color: var(--color-primary); }
    .blog-card-img-wrapper { width: 100%; height: 160px; overflow: hidden; background-color: var(--color-bg); display: flex; align-items: center; justify-content: center; }
    .blog-card-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
    .blog-card-link:hover .blog-card-img { transform: scale(1.05); }
    .blog-card-content { padding: 20px; flex: 1; display: flex; flex-direction: column; }
    .blog-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
    .blog-date { font-size: 0.9rem; color: #888; }
    .blog-tags { display: flex; gap: 8px; flex-wrap: wrap; }
    .tag { background: var(--color-bg); color: var(--color-primary); font-size: 0.8rem; padding: 4px 10px; border-radius: 20px; font-weight: bold; }
    .blog-title { font-size: 1.2rem; line-height: 1.5; margin: 0; color: var(--color-text); }
    .empty-text { color: #777; text-align: center; padding: 40px; background: white; border-radius: 12px; border: 1px dashed #ccc; width: 100%; font-size: 0.9rem; }

    .dict-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 25px; align-items: start; }
    
    .glossary-column { display: flex; flex-direction: column; gap: 20px; }
    .quiz-column { }

    .dict-card { background: white; padding: 25px; border-radius: 12px; border: 1px solid #e1ebe5; text-decoration: none; color: inherit; transition: transform 0.2s, box-shadow 0.2s; position: relative; overflow: hidden; display: flex; flex-direction: column; }
    .glossary-card { border-left: 4px solid var(--color-primary); }
    .glossary-card:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(78, 123, 103, 0.1); border-color: var(--color-primary); }

    .quiz-interactive-card { border: 2px solid var(--color-accent); background: #fdfdfd; height: 100%; }
    .quiz-badge { background: #fff1e6; color: #c2410c; }
    .quiz-q-text { font-size: 1.3rem; margin-bottom: 20px; color: var(--color-text); }
    
    .home-choices { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
    .home-choice-btn { display: flex; align-items: center; text-align: left; width: 100%; background: #f8fafc; border: 1px solid #cbd5e1; padding: 12px 15px; border-radius: 8px; font-size: 0.95rem; color: var(--color-text); cursor: pointer; transition: all 0.2s; }
    .home-choice-btn:hover { background: #f1f5f9; border-color: #94a3b8; }
    .home-choice-btn.selected { background: #e0f2fe; border-color: #0284c7; color: #0369a1; font-weight: bold; }
    .choice-number { display: inline-flex; justify-content: center; align-items: center; width: 24px; height: 24px; background: white; border: 1.5px solid currentcolor; border-radius: 50%; margin-right: 12px; font-size: 0.8rem; font-weight: bold; flex-shrink: 0; }
    .choice-text { line-height: 1.4; }

    .action-area { text-align: center; }
    .btn-primary-small { background: var(--color-primary); color: white; border: none; padding: 10px 30px; font-size: 1rem; font-weight: bold; border-radius: 30px; cursor: pointer; transition: opacity 0.2s; width: 100%; max-width: 300px; }
    .btn-primary-small:hover { opacity: 0.9; }
    .btn-primary-small:disabled { background: #cbd5e1; cursor: not-allowed; }

    .home-result-box { background: #f0fdf4; border: 2px solid #bbf7d0; border-radius: 8px; padding: 20px; animation: fadeIn 0.4s ease; margin-top: 10px; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
    
    .result-header { display: flex; align-items: center; gap: 10px; margin-bottom: 15px; border-bottom: 1px dashed #bbf7d0; padding-bottom: 15px; }
    .result-mark { font-size: 1.8rem; font-weight: bold; }
    .result-title { margin: 0; font-size: 1.2rem; color: #166534; }
    .explanation-content p { margin: 0; font-size: 0.95rem; line-height: 1.6; color: #333; }

    .more-quiz-action { margin-top: 20px; text-align: center; }
    .btn-more-quiz { display: inline-block; background: white; color: #c2410c; border: 2px solid #c2410c; padding: 8px 20px; border-radius: 20px; text-decoration: none; font-weight: bold; font-size: 0.9rem; transition: all 0.2s; }
    .btn-more-quiz:hover { background: #c2410c; color: white; }

    .text-center { text-align: center; }

    @media (max-width: 768px) {
        .hero-title { 
            font-size: 1.5rem; 
            line-height: 1.5; 
        }
        .hero-desc { font-size: 0.95rem; }
        .btn-primary { padding: 15px 30px; font-size: 1.1rem; width: 90%; box-sizing: border-box; }
        
        .section-header { flex-direction: column; align-items: flex-start; gap: 10px; }
        .section-title { 
            font-size: 1.4rem; 
        }
        
        .youtube-grid { grid-template-columns: 1fr; }
        .dict-grid { grid-template-columns: 1fr; }
    }
</style>

<script>
    // ホーム画面のクイズ用 クライアントサイドJavaScript
    const container = document.getElementById('home-quiz-container');
    if (container) {
        const btns = container.querySelectorAll('.home-choice-btn');
        const submitBtn = document.getElementById('home-quiz-submit') as HTMLButtonElement;
        const resultBox = document.getElementById('home-quiz-result') as HTMLElement;
        const mark = document.getElementById('home-result-mark') as HTMLElement;
        const correctAns = container.getAttribute('data-correct') || '';
        
        let selectedValue = '';

        // 選択肢クリック時の動作
        btns.forEach(btn => {
            btn.addEventListener('click', function() {
                btns.forEach(b => b.classList.remove('selected'));
                this.classList.add('selected');
                selectedValue = this.getAttribute('data-number') || '';
                
                submitBtn.disabled = false;
            });
        });

        // 答え合わせボタンクリック時の動作
        submitBtn?.addEventListener('click', function() {
            if (selectedValue === correctAns) {
                mark.textContent = '⭕️';
                mark.style.color = '#16a34a';
            } else {
                mark.textContent = '❌';
                mark.style.color = '#ef4444';
            }

            // 解説を表示し、ボタンを消す
            resultBox.style.display = 'block';
            this.style.display = 'none';

            // 選択肢をこれ以上クリックできないようにする
            btns.forEach(b => (b as HTMLButtonElement).style.pointerEvents = 'none');
        });
    }
</script>