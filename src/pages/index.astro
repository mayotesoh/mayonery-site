---
import Layout from '../layouts/Layout.astro';

// 🌟 新しいブログデータベースから最新記事を取得する処理
const apiKey = import.meta.env.NOTION_API_KEY;
const blogDbId = import.meta.env.NOTION_BLOG_ID;

let recentPosts = [];
try {
  const response = await fetch(`https://api.notion.com/v1/databases/${blogDbId}/query`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${apiKey}`,
      'Notion-Version': '2022-06-28',
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({
      sorts: [{ property: '日付', direction: 'descending' }]
    })
  });
  const data = await response.json();
  const allPosts = data.results || [];

  recentPosts = allPosts.filter((post: any) => {
    const status = post.properties['ステータス']?.status?.name || post.properties['ステータス']?.select?.name || '';
    return status === '公開';
  }).slice(0, 3);
} catch (error) {
  console.error('Notion APIからのデータ取得に失敗しました', error);
}
---

<Layout title="手相のマヨネリ | 根本解決の手相鑑定・自己分析ツール">
    
    <section class="hero-container">
        <div class="hero-content text-center">
            <h1 class="hero-title">手相は最強の<br>「自己分析ツール」である。</h1>
            <p class="hero-desc">運命を「当てる」のではなく、仕組みを「論理的」に紐解く。<br>迷信を排除した、根本解決のための手相学。</p>
            
            <div class="hero-actions">
                <a href="/shindan" class="btn-primary pulse-animation">
                    <span class="btn-icon">✋</span> 無料手相・性格診断を試す
                </a>
            </div>
        </div>
    </section>

    <div class="container main-content">
        
        <section class="top-section">
            <div class="section-header">
                <h2 class="section-title">最新のブログ・思考録</h2>
                <a href="/blog" class="view-all">すべて見る →</a>
            </div>
            
            <div class="blog-grid">
                {recentPosts.length > 0 ? (
                    recentPosts.map((post: any) => {
                        const title = post.properties['タイトル']?.title[0]?.plain_text || '無題';
                        const dateStr = post.properties['日付']?.date?.start || '';
                        const date = dateStr ? new Date(dateStr).toLocaleDateString('ja-JP') : '日付なし';
                        const categories = post.properties['カテゴリー']?.multi_select?.map((t: any) => t.name) || [];
                        const slug = post.properties['URLスラッグ']?.rich_text[0]?.plain_text || post.id;
                        
                        // 🌟 アイキャッチ画像の取得
                        const eyecatchProp = post.properties['アイキャッチ'];
                        let eyecatchUrl = '/favicon.png'; 
                        
                        if (eyecatchProp) {
                            if (eyecatchProp.type === 'rich_text' && eyecatchProp.rich_text.length > 0) {
                                const textUrl = eyecatchProp.rich_text[0].plain_text.trim();
                                if (textUrl !== "") eyecatchUrl = textUrl;
                            } else if (eyecatchProp.type === 'files' && eyecatchProp.files.length > 0) {
                                eyecatchUrl = eyecatchProp.files[0].type === 'file' ? eyecatchProp.files[0].file.url : eyecatchProp.files[0].external?.url;
                            }
                        }
                        
                        return (
                            <a href={`/blog/${slug}`} class="blog-card-link">
                                <article class="blog-card">
                                    <div class="blog-card-img-wrapper">
                                        <img src={eyecatchUrl} alt={title} class="blog-card-img" loading="lazy" />
                                    </div>
                                    <div class="blog-card-content">
                                        <div class="blog-meta">
                                            <time class="blog-date">{date}</time>
                                            <div class="blog-tags">
                                                {categories.map((cat: string) => (
                                                    <span class="tag">#{cat}</span>
                                                ))}
                                            </div>
                                        </div>
                                        <h3 class="blog-title">{title}</h3>
                                    </div>
                                </article>
                            </a>
                        );
                    })
                ) : (
                    <p class="empty-text">記事を準備中です。</p>
                )}
            </div>
        </section>

        <section class="top-section">
            <h2 class="section-title text-center">提供サービス</h2>
            <div class="service-grid">
                
                <div class="service-card">
                    <div class="s-icon">🔍</div>
                    <h3>手相鑑定</h3>
                    <p>オンライン・札幌対面にて、あなたの「設計」を論理的に読み解く個人鑑定を行います。</p>
                    <a href="/kantei" class="s-link">鑑定メニューを見る →</a>
                </div>

                <div class="service-card">
                    <div class="s-icon">📖</div>
                    <h3>手相講座</h3>
                    <p>迷信に依存しない、論理的で体系化された「根本解決の手相学」を学ぶ講座です。</p>
                    <a href="/kouza" class="s-link">講座一覧を見る →</a>
                </div>

                <div class="service-card">
                    <div class="s-icon">🤝</div>
                    <h3>手相学会</h3>
                    <p>手相学を深めるために疑問の共有や解説を行う完全無料のオープンコミュニティです。</p>
                    <a href="/gakkai" class="s-link">学会について見る →</a>
                </div>

            </div>
        </section>

    </div>
</Layout>

<style>
    /* 1. ヒーローセクション */
    .hero-container { background: linear-gradient(135deg, var(--color-primary), #2c4a3d); color: white; padding: 100px 15px; margin-bottom: 60px; }
    .hero-content { max-width: 800px; margin: 0 auto; }
    .hero-title { font-size: 3rem; line-height: 1.3; margin-bottom: 25px; letter-spacing: 0.05em; text-shadow: 0 2px 10px rgba(0,0,0,0.2); }
    .hero-desc { font-size: 1.2rem; line-height: 1.8; margin-bottom: 40px; opacity: 0.9; }
    
    .hero-actions { display: flex; justify-content: center; }
    .btn-primary { display: inline-block; background-color: white; color: var(--color-primary); padding: 18px 40px; font-size: 1.3rem; font-weight: bold; border-radius: 40px; text-decoration: none; box-shadow: 0 10px 25px rgba(0,0,0,0.2); transition: transform 0.2s; }
    .btn-primary:hover { transform: translateY(-3px); }
    .btn-icon { margin-right: 8px; font-size: 1.4rem; }

    .pulse-animation { animation: pulse 2s infinite; }
    @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.4); } 70% { box-shadow: 0 0 0 15px rgba(255, 255, 255, 0); } 100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); } }

    .main-content { padding-bottom: 60px; }
    .top-section { margin-bottom: 80px; }
    .section-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px; border-bottom: 2px solid var(--color-bg); padding-bottom: 10px; }
    .section-title { color: var(--color-primary); font-size: 1.8rem; margin: 0; }
    .view-all { color: var(--color-accent); font-weight: bold; text-decoration: none; transition: opacity 0.2s; }
    .view-all:hover { opacity: 0.7; }

    /* 2. ブロググリッド (画像を組み込んだスタイルに修正) */
    .blog-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px; }
    .blog-card-link { text-decoration: none; color: inherit; display: block; }
    .blog-card { background: white; border-radius: 12px; border: 1px solid #e1ebe5; box-shadow: 0 4px 10px rgba(0,0,0,0.03); transition: transform 0.2s, box-shadow 0.2s; height: 100%; display: flex; flex-direction: column; overflow: hidden; }
    .blog-card-link:hover .blog-card { transform: translateY(-5px); box-shadow: 0 8px 20px rgba(78, 123, 103, 0.1); border-color: var(--color-primary); }
    
    /* 🌟 画像用のスタイル追加 */
    .blog-card-img-wrapper { width: 100%; height: 160px; overflow: hidden; background-color: var(--color-bg); display: flex; align-items: center; justify-content: center; }
    .blog-card-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
    .blog-card-link:hover .blog-card-img { transform: scale(1.05); }
    
    .blog-card-content { padding: 20px; flex: 1; display: flex; flex-direction: column; }
    .blog-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
    .blog-date { font-size: 0.9rem; color: #888; }
    .blog-tags { display: flex; gap: 8px; flex-wrap: wrap; }
    .tag { background: var(--color-bg); color: var(--color-primary); font-size: 0.8rem; padding: 4px 10px; border-radius: 20px; font-weight: bold; }
    .blog-title { font-size: 1.2rem; line-height: 1.5; margin: 0; color: var(--color-text); }
    .empty-text { color: #777; text-align: center; padding: 40px; background: white; border-radius: 12px; border: 1px dashed #ccc; width: 100%; }

    /* 3. サービス一覧 */
    .service-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 30px; margin-top: 40px; }
    .service-card { background: white; padding: 40px 25px; border-radius: 16px; text-align: center; border: 1px solid #e1ebe5; box-shadow: 0 4px 15px rgba(0,0,0,0.03); }
    .s-icon { font-size: 3rem; margin-bottom: 20px; }
    .service-card h3 { color: var(--color-primary); font-size: 1.4rem; margin-bottom: 15px; }
    .service-card p { color: #555; line-height: 1.7; font-size: 0.95rem; margin-bottom: 25px; }
    .s-link { display: inline-block; color: var(--color-accent); font-weight: bold; text-decoration: none; border-bottom: 2px solid transparent; transition: border-color 0.2s; }
    .s-link:hover { border-color: var(--color-accent); }

    .text-center { text-align: center; }

    @media (max-width: 768px) {
        .hero-title { font-size: 2.2rem; }
        .hero-desc { font-size: 1rem; }
        .btn-primary { padding: 15px 30px; font-size: 1.1rem; }
        .section-header { flex-direction: column; align-items: flex-start; gap: 10px; }
    }
</style>