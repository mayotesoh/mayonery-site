---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const apiKey = import.meta.env.NOTION_API_KEY;
const databaseId = import.meta.env.NOTION_DATABASE_ID;

const response = await fetch(`https://api.notion.com/v1/databases/${databaseId}/query`, {
  method: 'POST',
  headers: {
    'Authorization': `Bearer ${apiKey}`,
    'Notion-Version': '2022-06-28',
    'Content-Type': 'application/json',
  },
});

const data = await response.json();
const posts = data.results || [];
---

<!doctype html>
<html lang="ja">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            /* 記事リストを少し見やすくするスタイル */
            .post-list {
                margin-top: 2rem;
                padding-left: 1rem;
            }
            .post-list li {
                margin-bottom: 0.5rem;
                list-style-type: "✋ "; /* マヨネリ様らしく手相アイコンを箇条書きに */
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <h1>✋ マヨネリ手相・思考録へようこそ</h1>
            <p>
                ここは、表面的な「吉凶」に惑わされず、手相の根幹である「地丘（生活の基盤）」から
                自分自身の現在地と未来を紐解いていくためのポータルサイトです。
            </p>
            <p>
                YouTubeでの発信内容の深掘りや、従来とは異なる手相の解釈、
                そして日々の思考の記録をここにストックしていきます。
            </p>

            <section>
                <h3>最新の思考録（Notion自動連携）</h3>
                <ul class="post-list">
                    {posts.length > 0 ? (
                        posts.map((post) => (
                            <li>
                                {post.properties['タイトル']?.title[0]?.plain_text || '（タイトルなし）'}
                            </li>
                        ))
                    ) : (
                        <li>記事を読み込み中、または記事がありません。</li>
                    )}
                </ul>
            </section>
        </main>
        <Footer />
    </body>
</html>