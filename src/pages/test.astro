---
// 翻訳機（SDK）を使わず、Astro標準の機能で直接Notionへ通信します
const apiKey = import.meta.env.NOTION_API_KEY;
const databaseId = import.meta.env.NOTION_DATABASE_ID;

// Notionへ「直接」リクエストを送る
const response = await fetch(`https://api.notion.com/v1/databases/${databaseId}/query`, {
  method: 'POST',
  headers: {
    'Authorization': `Bearer ${apiKey}`,
    'Notion-Version': '2022-06-28',
    'Content-Type': 'application/json',
  },
});

// 返ってきたデータを解析
const data = await response.json();
const posts = data.results || [];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>Notion通信テスト</title>
  </head>
  <body style="font-family: sans-serif; padding: 2rem;">
    <h1>📡 Notion連携テスト画面</h1>
    <p>Notionのデータベースから <strong>{posts.length}</strong> 件の記事データを読み込みました！</p>
    
    <h2>▼ 取得した記事のタイトル</h2>
    <ul>
      {posts.map((post) => (
        <li>
          {post.properties['タイトル']?.title[0]?.plain_text || '（タイトルなし）'}
        </li>
      ))}
    </ul>
  </body>
</html>