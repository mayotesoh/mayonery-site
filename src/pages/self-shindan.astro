    // ── 生命線（ライフスタイル）の相性 ──
    const diffS9 = Math.abs(y.s9 - p.s9);
    if (diffS9 > 30) { score -= 10; textLife += "休日の過ごし方（インドア派かアウトドア派か）に違いがあります。どちらかが無理して合わせすぎないよう、それぞれの時間も楽しむ配慮が必要です。"; }
    else { textLife += "休日の過ごし方や環境への適応力が似ており、一緒に過ごす時間がとても充実します。"; }

