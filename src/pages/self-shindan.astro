---
import Layout from '../layouts/Layout.astro';
---

<Layout title="セルフ手相診断機 | 手相のマヨネリ">

  <div class="ssw">

    <div class="ssw-hero">
      <h1 class="ssw-title">セルフ手相診断機</h1>
      <p class="ssw-sub">自分の手相の形を入力して、隠された性質や才能を客観的に分析しましょう</p>
    </div>

    <div class="ssw-layout">

      <aside class="ssw-panel">

        <div class="ssw-sec-head" style="color:var(--ssw-heart)">感情線（Heart Line）</div>

        <div class="ssw-srow ssw-hl">
          <div class="ssw-smeta">
            <span class="ssw-sname">① 起点位置</span>
            <span class="ssw-sval" id="v1">50</span>
          </div>
          <div class="ssw-strack">
            <span class="ssw-send-l">低い</span>
            <input type="range" id="s1" min="0" max="100" value="50" />
            <span class="ssw-send-r">高い</span>
          </div>
        </div>
        <div class="ssw-srow ssw-hl">
          <div class="ssw-smeta">
            <span class="ssw-sname">② 長さ</span>
            <span class="ssw-sval" id="v2">50</span>
          </div>
          <div class="ssw-strack">
            <span class="ssw-send-l">短い</span>
            <input type="range" id="s2" min="0" max="100" value="50" />
            <span class="ssw-send-r">長い</span>
          </div>
        </div>
        <div class="ssw-srow ssw-hl">
          <div class="ssw-smeta">
            <span class="ssw-sname">③ カーブ</span>
            <span class="ssw-sval" id="v3">50</span>
          </div>
          <div class="ssw-strack">
            <span class="ssw-send-l">下向き</span>
            <input type="range" id="s3" min="0" max="100" value="50" />
            <span class="ssw-send-r">上向き</span>
          </div>
        </div>

        <div class="ssw-divider"></div>
        <div class="ssw-sec-head" style="color:var(--ssw-head)">頭脳線（Head Line）</div>

        <div class="ssw-srow ssw-hl2">
          <div class="ssw-smeta">
            <span class="ssw-sname">④ 起点位置</span>
            <span class="ssw-sval" id="v4">50</span>
          </div>
          <div class="ssw-strack">
            <span class="ssw-send-l">低い</span>
            <input type="range" id="s4" min="0" max="100" value="50" />
            <span class="ssw-send-r">高い</span>
          </div>
        </div>
        <div class="ssw-srow ssw-hl2">
          <div class="ssw-smeta">
            <span class="ssw-sname">⑤ 長さ</span>
            <span class="ssw-sval" id="v5">50</span>
          </div>
          <div class="ssw-strack">
            <span class="ssw-send-l">短い</span>
            <input type="range" id="s5" min="0" max="100" value="50" />
            <span class="ssw-send-r">長い</span>
          </div>
        </div>
        <div class="ssw-srow ssw-hl2">
          <div class="ssw-smeta">
            <span class="ssw-sname">⑥ 向き</span>
            <span class="ssw-sval" id="v6">50</span>
          </div>
          <div class="ssw-strack">
            <span class="ssw-send-l">下向き</span>
            <input type="range" id="s6" min="0" max="100" value="50" />
            <span class="ssw-send-r">水平</span>
          </div>
        </div>

        <div class="ssw-divider"></div>
        <div class="ssw-sec-head" style="color:var(--ssw-life)">生命線（Life Line）</div>

        <div class="ssw-srow ssw-ll">
          <div class="ssw-smeta">
            <span class="ssw-sname">⑦ 起点位置</span>
            <span class="ssw-sval" id="v7">50</span>
          </div>
          <div class="ssw-strack">
            <span class="ssw-send-l">低い</span>
            <input type="range" id="s7" min="0" max="100" value="50" />
            <span class="ssw-send-r">高い</span>
          </div>
        </div>
        <div class="ssw-srow ssw-ll">
          <div class="ssw-smeta">
            <span class="ssw-sname">⑧ 張り・膨らみ</span>
            <span class="ssw-sval" id="v8">50</span>
          </div>
          <div class="ssw-strack">
            <span class="ssw-send-l">小さい</span>
            <input type="range" id="s8" min="0" max="100" value="50" />
            <span class="ssw-send-r">大きい</span>
          </div>
        </div>
        <div class="ssw-srow ssw-ll">
          <div class="ssw-smeta">
            <span class="ssw-sname">⑨ 終点</span>
            <span class="ssw-sval" id="v9">50</span>
          </div>
          <div class="ssw-strack">
            <span class="ssw-send-l">内側</span>
            <input type="range" id="s9" min="0" max="100" value="50" />
            <span class="ssw-send-r">外側</span>
          </div>
        </div>

        <div class="ssw-divider"></div>
        <div class="ssw-sec-head" style="color:var(--ssw-hand)">手の形・指</div>

        <div class="ssw-srow ssw-hd">
          <div class="ssw-smeta">
            <span class="ssw-sname">⑩ 手のひらの形</span>
            <span class="ssw-sval" id="v10">50</span>
          </div>
          <div class="ssw-strack">
            <span class="ssw-send-l">幅広</span>
            <input type="range" id="s10" min="0" max="100" value="50" />
            <span class="ssw-send-r">縦長</span>
          </div>
        </div>
        <div class="ssw-srow ssw-hd">
          <div class="ssw-smeta">
            <span class="ssw-sname">⑪ 指の長さ</span>
            <span class="ssw-sval" id="v11">50</span>
          </div>
          <div class="ssw-strack">
            <span class="ssw-send-l">短い</span>
            <input type="range" id="s11" min="0" max="100" value="50" />
            <span class="ssw-send-r">長い</span>
          </div>
        </div>

        <button class="ssw-reset-btn" id="reset-btn">すべてリセット</button>
        <button class="ssw-diagnose-btn" id="diagnose-btn">この手相を診断する</button>
      </aside>

      <div class="ssw-preview">
        <svg class="ssw-palm-svg" viewBox="0 0 625 777" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <radialGradient id="palmFillSsw" cx="50%" cy="54%" r="54%">
              <stop offset="0%"   stop-color="rgba(78, 123, 103, 0.08)" />
              <stop offset="100%" stop-color="rgba(78, 123, 103, 0)" />
            </radialGradient>
          </defs>

          <path id="hand-glow"
            d="M109.255 636C133.255 693.5 167.97 715.5 198.47 744C228.971 772.5 312.47 776.5 351.47 776.5C390.47 776.5 488.47 775.5 522.97 744C557.47 712.5 571.97 663.5 577.47 591.5C582.97 519.5 583.47 409 583.47 409C583.47 409 659.47 169.5 604.47 148.5C549.47 127.5 494.47 352.5 494.47 352.5C494.47 352.5 560.97 70 494.47 54C427.97 38 395.47 331.5 395.47 331.5C395.47 331.5 422.47 0.5 351.47 0.5C280.47 0.5 287.47 331.5 287.47 331.5C287.47 331.5 258.47 43.9885 189.971 54C121.471 64.0115 183.471 347 183.471 347C183.471 347 189.971 364 189.971 415.5C189.971 467 183.471 538 183.471 538C183.471 538 51.4705 352 9.47048 409C-32.5295 466 85.2548 578.5 109.255 636Z"
            fill="url(#palmFillSsw)" stroke="none" />

          <path id="hand-path"
            d="M109.255 636C133.255 693.5 167.97 715.5 198.47 744C228.971 772.5 312.47 776.5 351.47 776.5C390.47 776.5 488.47 775.5 522.97 744C557.47 712.5 571.97 663.5 577.47 591.5C582.97 519.5 583.47 409 583.47 409C583.47 409 659.47 169.5 604.47 148.5C549.47 127.5 494.47 352.5 494.47 352.5C494.47 352.5 560.97 70 494.47 54C427.97 38 395.47 331.5 395.47 331.5C395.47 331.5 422.47 0.5 351.47 0.5C280.47 0.5 287.47 331.5 287.47 331.5C287.47 331.5 258.47 43.9885 189.971 54C121.471 64.0115 183.471 347 183.471 347C183.471 347 189.971 364 189.971 415.5C189.971 467 183.471 538 183.471 538C183.471 538 51.4705 352 9.47048 409C-32.5295 466 85.2548 578.5 109.255 636Z" />

          <line x1="352" y1="655" x2="352" y2="420"
                stroke="rgba(0,0,0,0.08)" stroke-width="1.8"
                stroke-dasharray="6,9" stroke-linecap="round"/>

          <path id="life-line"  />
          <path id="head-line"  />
          <path id="heart-line" />
        </svg>

        <div class="ssw-legend">
          <div class="ssw-leg"><div class="ssw-leg-bar" style="background:var(--ssw-heart)"></div>感情線</div>
          <div class="ssw-leg"><div class="ssw-leg-bar" style="background:var(--ssw-head)"></div>頭脳線</div>
          <div class="ssw-leg"><div class="ssw-leg-bar" style="background:var(--ssw-life)"></div>生命線</div>
        </div>
      </div>
    </div>

    <div id="ssw-result-panel" class="ssw-result-hidden">
      <div class="ssw-result-inner">
        <h2 class="ssw-result-title">手相診断レポート</h2>
        <p class="ssw-result-sub">手相に刻まれた特徴から読み取れる、あなたの性質の傾向です。どちらが優れているということはありません。</p>
        <div id="ssw-result-body"></div>
        <button class="ssw-result-close" id="result-close">再診断する（閉じる）</button>
      </div>
    </div>

  </div></Layout>

<style is:global>
  /* Result panel overlay (Light Mode) */
  #ssw-result-panel {
    position: fixed;
    inset: 0;
    background: rgba(242, 246, 244, 0.85); /* サイトの背景色を透過 */
    backdrop-filter: blur(8px);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  #ssw-result-panel.ssw-result-hidden { display: none; }

  .ssw-result-inner {
    background: #ffffff;
    border: 1px solid #d1e0d7;
    border-radius: 20px;
    padding: 2.5rem 2.5rem;
    max-width: 750px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    color: var(--color-text);
    box-shadow: 0 15px 35px rgba(29, 51, 42, 0.1);
    font-family: system-ui, -apple-system, 'Segoe UI', 'Hiragino Sans', sans-serif;
  }
  .ssw-result-title {
    font-size: 1.3rem;
    color: var(--color-primary);
    margin: 0 0 0.5rem;
    letter-spacing: 0.1em;
    text-align: center;
    font-weight: bold;
  }
  .ssw-result-sub {
    font-size: 0.8rem;
    color: #7a9487;
    margin: 0 0 2.5rem;
    text-align: center;
  }
  .ssw-result-close {
    display: block;
    width: 100%;
    margin-top: 2rem;
    padding: 1rem;
    background: var(--color-primary);
    border: none;
    border-radius: 12px;
    box-shadow: 0 4px 0 var(--color-accent), 0 6px 15px rgba(78, 123, 103, 0.2);
    color: #ffffff;
    font-size: 1rem;
    font-weight: bold;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
  }
  .ssw-result-close:hover { 
    background: var(--color-accent);
    transform: translateY(-2px); 
    box-shadow: 0 6px 0 var(--color-accent), 0 8px 20px rgba(78, 123, 103, 0.3);
  }
  .ssw-result-close:active {
    transform: translateY(4px); box-shadow: 0 0 0 transparent;
  }

  /* Dynamic result sections */
  #ssw-result-body .result-section { margin-bottom: 2.5rem; }
  #ssw-result-body .result-heading {
    font-size: 0.95rem;
    color: var(--color-accent);
    font-weight: bold;
    margin-bottom: 1.2rem;
    border-bottom: 1px solid #d1e0d7;
    padding-bottom: 0.4rem;
    letter-spacing: 0.1em;
  }
  #ssw-result-body .summary-box {
    background: var(--color-bg);
    border-left: 4px solid var(--color-primary);
    padding: 1.2rem 1.5rem;
    border-radius: 4px 12px 12px 4px;
    margin-bottom: 2rem;
  }
  #ssw-result-body .summary-box p {
    font-size: 0.85rem;
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: 0.8rem;
  }
  #ssw-result-body .summary-box p:last-child { margin-bottom: 0; }
  
  #ssw-result-body .spider-wrap { display: flex; justify-content: center; margin: 1rem 0; }
  #ssw-result-body .spider-wrap svg { width: 100%; max-width: 480px; }
  
  #ssw-result-body .allocation-chart-container {
    display: flex; align-items: center; justify-content: center;
    gap: 2.5rem; flex-wrap: wrap; margin-bottom: 1.5rem;
  }
  #ssw-result-body .donut-chart {
    width: 170px; height: 170px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 0 20px rgba(0,0,0,0.05);
    transition: background 0.5s ease-out; flex-shrink: 0;
  }
  #ssw-result-body .donut-inner {
    width: 130px; height: 130px;
    background: #ffffff;
    border-radius: 50%; display: flex; align-items: center;
    justify-content: center; box-shadow: inset 0 0 12px rgba(0,0,0,0.05);
  }
  #ssw-result-body .donut-total {
    font-size: 0.75rem; color: #7a9487;
    text-align: center; letter-spacing: 0.1em; line-height: 1.4; font-weight: bold;
  }
  #ssw-result-body .stat-labels { display: flex; flex-direction: column; gap: 0.8rem; }
  #ssw-result-body .stat-lbl {
    font-size: 0.85rem; color: var(--color-text); font-weight: 500;
    display: flex; align-items: center; gap: 0.5rem;
  }
  
  #ssw-result-body .quad-section {
    margin-top: 1.8rem; border-top: 1px solid #d1e0d7; padding-top: 1.8rem;
  }
  #ssw-result-body .quad-section h3 {
    font-size: 0.85rem; color: var(--color-accent);
    letter-spacing: 0.1em; margin: 0 0 1.2rem; text-align: center; font-weight: bold;
  }
  #ssw-result-body .quad-wrap { display: flex; justify-content: center; }
  #ssw-result-body .quad-wrap svg { width: 100%; max-width: 380px; }
  
  #ssw-result-body .type-card {
    margin-top: 1.2rem; background: var(--color-bg);
    border: 1px solid #d1e0d7; border-radius: 12px;
    padding: 1.5rem 1.2rem; text-align: center;
  }
  #ssw-result-body .type-name {
    font-size: 1.1rem; font-weight: 700; color: var(--color-primary);
    margin-bottom: 0.6rem; letter-spacing: 0.04em;
  }
  #ssw-result-body .type-desc {
    font-size: 0.85rem; color: var(--color-text); line-height: 1.6; opacity: 0.9;
  }
  
  @media (max-width: 600px) {
    .ssw-result-inner { padding: 1.5rem 1.2rem; border-radius: 14px; }
    #ssw-result-body .allocation-chart-container { gap: 1.5rem; }
    #ssw-result-body .donut-chart { width: 140px; height: 140px; }
    #ssw-result-body .donut-inner { width: 106px; height: 106px; }
  }
</style>

<style>
  /* ── Wrapper: Light Mode matched to Site ── */
  .ssw {
    /* サイト全体の変数をそのまま使用 */
    --ssw-bg: var(--color-bg);
    --ssw-surface: #ffffff;
    --ssw-border: #d1e0d7;
    --ssw-text: var(--color-text);
    --ssw-muted: #7a9487;
    --ssw-accent: var(--color-primary);
    
    /* ラインの色：白背景に映えるよう少し濃いめに調整 */
    --ssw-heart: #d9467d; /* 落ち着いた濃いピンク */
    --ssw-head: #2b6cb0;  /* 落ち着いた青 */
    --ssw-life: var(--color-primary); /* サイトの緑 */
    --ssw-hand: #d97706;  /* 落ち着いたゴールド */

    background: transparent;
    color: var(--ssw-text);
    font-family: inherit;
    padding-bottom: 4rem;
  }

  /* ── Hero / Intro ── */
  .ssw-hero {
    text-align: center;
    padding: 2.8rem 1rem 1.8rem;
    position: relative;
  }
  .ssw-hero::after {
    content: '';
    position: absolute;
    bottom: 0; left: 50%; transform: translateX(-50%);
    width: min(600px, 80%); height: 1px;
    background: linear-gradient(90deg, transparent, var(--ssw-border), transparent);
  }
  .ssw-title {
    font-size: clamp(1.6rem, 4.5vw, 2.4rem);
    font-weight: 800;
    letter-spacing: 0.05em;
    background: none;
    -webkit-text-fill-color: initial;
    color: var(--color-primary); /* サイトのメインカラーに統一 */
    margin: 0 0 0.5rem;
  }
  .ssw-sub {
    font-size: 0.84rem;
    color: var(--ssw-muted);
    letter-spacing: 0.04em;
    margin: 0;
  }

  /* ── Main layout ── */
  .ssw-layout {
    display: grid;
    grid-template-columns: 348px 1fr;
    gap: 1.5rem;
    max-width: 1100px;
    margin: 1.8rem auto 0;
    padding: 0 1.5rem;
  }
  /* ── Panel ── */
  .ssw-panel {
    background: var(--ssw-surface);
    border: 1px solid var(--ssw-border);
    border-radius: 18px;
    padding: 1.5rem 1.25rem 1.25rem;
    height: fit-content;
    position: sticky;
    top: 80px;
    box-shadow: 0 4px 15px rgba(78, 123, 103, 0.05); /* ほんのり緑の影 */
  }

  @media (max-width: 860px) {
    /* レイアウトのフレックスを解除して通常のブロック配置に */
    .ssw-layout { 
      display: block; 
      padding: 0;
    }

    /* プレビュー（手相画像）を画面上部に完全に固定 */
    .ssw-preview {
      position: fixed;
      top: 70px;
      left: 0;
      width: 100%;
      height: 40vh;
      z-index: 100;
      background: #ffffff;
      border-radius: 0;
      border-left: none;
      border-right: none;
      border-top: none;
      border-bottom: 1px solid var(--ssw-border);
      padding: 1rem 0.5rem 0.5rem;
      box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    /* 手の画像を固定枠の高さに綺麗にフィットさせる */
    .ssw-palm-svg {
      height: 100%;
      max-height: 100%;
      width: auto;
      display: block;
      margin: 0 auto;
    }

    /* 凡例をコンパクトに調整 */
    .ssw-legend {
      margin-top: 0.4rem;
      gap: 0.8rem;
    }
    .ssw-leg { font-size: 0.65rem; }

    /* スライダー側（パネル）が、固定された手相画像の下からスタートするようにトップに大きな余白を空ける */
    .ssw-panel { 
      margin-top: calc(40vh + 70px);
      border: none;
      border-radius: 0;
      box-shadow: none;
      padding: 1.5rem 1rem 3rem;
    }
  }

  .ssw-sec-head {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .ssw-sec-head::before {
    content: '';
    width: 7px; height: 7px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
    box-shadow: 0 0 6px currentColor;
  }
  .ssw-divider { height: 1px; background: var(--ssw-border); margin: 1rem 0; }

  /* ── Slider Row ── */
  .ssw-srow { margin-bottom: 0.75rem; }
  .ssw-smeta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.28rem; }
  .ssw-sname { font-size: 0.8rem; font-weight: 600; color: var(--ssw-text); }
  .ssw-sval {
    font-size: 0.7rem; font-weight: 700;
    padding: 0.06rem 0.38rem; border-radius: 4px;
    min-width: 26px; text-align: center;
  }
  .ssw-strack { display: flex; align-items: center; gap: 0.45rem; }
  .ssw-strack input[type=range] { flex: 1; min-width: 0; }
  .ssw-send-l, .ssw-send-r {
    font-size: 0.65rem; color: var(--ssw-muted); font-weight: bold;
    white-space: nowrap; flex-shrink: 0; width: 4.8em;
  }
  .ssw-send-l { text-align: right; }
  .ssw-send-r { text-align: left; }

  /* Range base */
  .ssw input[type=range] {
    -webkit-appearance: none;
    width: 100%; height: 4px; border-radius: 2px; outline: none; cursor: pointer;
  }
  .ssw input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px; height: 16px; border-radius: 50%;
    border: 2px solid #ffffff; cursor: grab; /* ツマミのフチを白に */
    transition: transform 0.12s, box-shadow 0.12s;
  }
  .ssw input[type=range]::-webkit-slider-thumb:active { cursor: grabbing; transform: scale(1.3); }
  .ssw input[type=range]::-moz-range-track { height: 4px; border-radius: 2px; border: none; }
  .ssw input[type=range]::-moz-range-thumb {
    width: 16px; height: 16px; border-radius: 50%; border: 2px solid #ffffff; cursor: grab;
  }

  .ssw-hl input[type=range] { background: rgba(217,70,125,0.15); }
  .ssw-hl input[type=range]::-webkit-slider-thumb { background: var(--ssw-heart); box-shadow: 0 0 6px rgba(217,70,125,0.4); }
  .ssw-hl .ssw-sval { color: var(--ssw-heart); background: rgba(217,70,125,0.1); }

  .ssw-hl2 input[type=range] { background: rgba(43,108,176,0.15); }
  .ssw-hl2 input[type=range]::-webkit-slider-thumb { background: var(--ssw-head); box-shadow: 0 0 6px rgba(43,108,176,0.4); }
  .ssw-hl2 .ssw-sval { color: var(--ssw-head); background: rgba(43,108,176,0.1); }

  .ssw-ll input[type=range] { background: rgba(78,123,103,0.15); }
  .ssw-ll input[type=range]::-webkit-slider-thumb { background: var(--ssw-life); box-shadow: 0 0 6px rgba(78,123,103,0.4); }
  .ssw-ll .ssw-sval { color: var(--ssw-life); background: rgba(78,123,103,0.1); }

  .ssw-hd input[type=range] { background: rgba(217,119,6,0.15); }
  .ssw-hd input[type=range]::-webkit-slider-thumb { background: var(--ssw-hand); box-shadow: 0 0 6px rgba(217,119,6,0.4); }
  .ssw-hd .ssw-sval { color: var(--ssw-hand); background: rgba(217,119,6,0.1); }

  /* Reset button (メインサイトのナビボタンと同じ装飾) */
  .ssw-reset-btn {
    display: block; width: 100%; margin-top: 1.25rem;
    padding: 0.6rem 1rem; 
    background-color: #ffffff; 
    border-radius: 12px; 
    border: 1px solid #e1ebe5; 
    box-shadow: 0 4px 0 #d1e0d7, 0 5px 10px rgba(78, 123, 103, 0.06);
    color: var(--ssw-muted); font-size: 0.8rem; font-weight: bold; letter-spacing: 0.06em;
    cursor: pointer; transition: all 0.2s ease;
    font-family: inherit;
  }
  .ssw-reset-btn:hover { 
    color: var(--color-primary); transform: translateY(-2px); 
    box-shadow: 0 6px 0 #d1e0d7, 0 8px 15px rgba(78, 123, 103, 0.12); 
  }
  .ssw-reset-btn:active { transform: translateY(4px); box-shadow: 0 0 0 transparent; }

  /* Diagnose button */
  .ssw-diagnose-btn {
    display: block; width: 100%; margin-top: 0.85rem;
    padding: 0.85rem 1rem;
    background: var(--color-primary); /* メインカラーのベタ塗り */
    border: none;
    border-radius: 12px;
    color: #ffffff; font-size: 0.9rem; font-weight: bold;
    letter-spacing: 0.08em; cursor: pointer;
    box-shadow: 0 4px 0 var(--color-accent), 0 5px 10px rgba(78, 123, 103, 0.15);
    transition: all 0.2s ease;
    font-family: inherit;
  }
  .ssw-diagnose-btn:hover {
    background: #5a8a75;
    transform: translateY(-2px);
    box-shadow: 0 6px 0 var(--color-accent), 0 8px 15px rgba(78, 123, 103, 0.2);
  }
  .ssw-diagnose-btn:active { transform: translateY(4px); box-shadow: 0 0 0 transparent; }

  /* ── Preview Panel (ライトモード) ── */
  .ssw-preview {
    background: #ffffff;
    border: 1px solid var(--ssw-border);
    border-radius: 18px;
    padding: 1.5rem;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    min-height: 520px;
    position: relative; overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }

  .ssw-palm-svg {
    width: 100%; max-width: 420px; height: auto;
    overflow: visible; transform-origin: 50% 100%;
    transition: transform 0.25s ease;
  }

  /* SVG hand / lines */
  #hand-path {
    fill: rgba(242, 246, 244, 0.8);
    stroke: var(--color-text);
    stroke-width: 2.2;
    stroke-linejoin: round;
    stroke-linecap: round;
  }
  #heart-line {
    fill: none; stroke: var(--ssw-heart); stroke-width: 2.8; stroke-linecap: round;
    filter: drop-shadow(0 0 3px rgba(217,70,125,0.3));
  }
  #head-line {
    fill: none; stroke: var(--ssw-head); stroke-width: 2.8; stroke-linecap: round;
    filter: drop-shadow(0 0 3px rgba(43,108,176,0.3));
  }
  #life-line {
    fill: none; stroke: var(--ssw-life); stroke-width: 2.8; stroke-linecap: round;
    filter: drop-shadow(0 0 3px rgba(78,123,103,0.3));
  }

  /* Legend */
  .ssw-legend { display: flex; gap: 1.6rem; margin-top: 1.2rem; flex-wrap: wrap; justify-content: center; }
  .ssw-leg { display: flex; align-items: center; gap: 0.4rem; font-size: 0.74rem; color: var(--ssw-text); font-weight: bold; }
  .ssw-leg-bar { width: 22px; height: 3px; border-radius: 2px; }
</style>

<script is:inline data-astro-rerun>
(function () {
  'use strict';

  const lerp = (a, b, t) => a + (b - a) * t;
  const R    = n => parseFloat(n.toFixed(1));

  const IDS = ['s1','s2','s3','s4','s5','s6','s7','s8','s9','s10','s11'];
  const sliders = {};
  IDS.forEach(id => { sliders[id] = document.getElementById(id); });
  const t = id => parseInt(sliders[id].value, 10) / 100;

  const ORIG_PATH = 'M109.255 636C133.255 693.5 167.97 715.5 198.47 744C228.971 772.5 312.47 776.5 351.47 776.5C390.47 776.5 488.47 775.5 522.97 744C557.47 712.5 571.97 663.5 577.47 591.5C582.97 519.5 583.47 409 583.47 409C583.47 409 659.47 169.5 604.47 148.5C549.47 127.5 494.47 352.5 494.47 352.5C494.47 352.5 560.97 70 494.47 54C427.97 38 395.47 331.5 395.47 331.5C395.47 331.5 422.47 0.5 351.47 0.5C280.47 0.5 287.47 331.5 287.47 331.5C287.47 331.5 258.47 43.9885 189.971 54C121.471 64.0115 183.471 347 183.471 347C183.471 347 189.971 364 189.971 415.5C189.971 467 183.471 538 183.471 538C183.471 538 51.4705 352 9.47048 409C-32.5295 466 85.2548 578.5 109.255 636Z';

  function morphPath(t10, fyScale) {
    const CX = 312, BY = 340, MAX_Y = 777;
    const venusPower = t10 < 0.5 ? lerp(1, 0.8, t10 * 2) : lerp(0.8, 0, (t10 - 0.5) * 2);
    const moonPower  = t10 < 0.5 ? lerp(0, 0.2, t10 * 2) : lerp(0.2, 1, (t10 - 0.5) * 2);

    const tx = (x, y) => {
      let nx = x;
      if (y > BY && x < CX) {
        const depth       = Math.min(1, (y - BY) / (MAX_Y - BY));
        const widthFactor = Math.min(1, (CX - x) / CX);
        nx -= venusPower * 65 * Math.pow(depth, 0.8) * widthFactor;
      }
      return parseFloat(nx.toFixed(2));
    };
    const ty = (x, y) => {
      let ny = y < BY ? BY - (BY - y) * fyScale : y;
      if (y > BY && x > CX) {
        const depth       = Math.min(1, (y - BY) / (MAX_Y - BY));
        const widthFactor = Math.min(1, (x - CX) / (625 - CX));
        ny += moonPower * 65 * Math.pow(depth, 1.2) * widthFactor;
      }
      return parseFloat(ny.toFixed(2));
    };

    const parts = [];
    const segRe = /([MmCcZz])([^MmCcZz]*)/g;
    const numRe = /-?[0-9]*\.?[0-9]+(?:e[-+]?[0-9]+)?/g;
    let seg;
    while ((seg = segRe.exec(ORIG_PATH)) !== null) {
      const cmd = seg[1];
      if (cmd === 'Z' || cmd === 'z') { parts.push(cmd); continue; }
      const ns = (seg[2].match(numRe) || []).map(Number);
      let s = cmd;
      for (let i = 0; i < ns.length; i += 2) {
        if (i > 0) s += ' ';
        s += tx(ns[i], ns[i+1]) + ' ' + ty(ns[i], ns[i+1]);
      }
      parts.push(s);
    }
    return parts.join('');
  }

  function heartPath() {
    const sY = R(lerp(536, 456, lerp(0.20, 1.0, t('s1'))));
    const eX = R(lerp(357, 207, t('s2')));
    const s3 = t('s3') < 0.5 ? lerp(0.27, 0.5, t('s3') * 2) : lerp(0.5, 1.0, (t('s3') - 0.5) * 2);
    const eYOffset = s3 < 0.5 ? lerp(60, -98, s3 * 2) : lerp(-98, -153, (s3 - 0.5) * 2);
    const eY   = R(sY + eYOffset);
    const archH = s3 < 0.5 ? lerp(-30, 20, s3 * 2) : lerp(20, 33, (s3 - 0.5) * 2);
    const cp1X = R(562 + (eX - 562) * 0.35);
    const cp2X = R(562 + (eX - 562) * 0.65);
    const cp1Y = R(sY + (eY - sY) * 0.35 + archH);
    const cp2Y = R(sY + (eY - sY) * 0.65 + archH);
    return `M 562,${sY} C ${cp1X},${cp1Y} ${cp2X},${cp2Y} ${eX},${eY}`;
  }

  function headPath() {
    const sX = 195;
    const sY = R(lerp(494, 374, lerp(0.14, 0.70, t('s4'))));
    const eX = R(lerp(362, 570, t('s5')));
    const maxDropForCurrentLength = lerp(130, 230, t('s5'));
    const drop = lerp(maxDropForCurrentLength, 30, t('s6'));
    const eY   = R(sY + drop);
    const cp1X = R(sX + (eX - sX) * 0.25);
    const cp2X = R(sX + (eX - sX) * 0.65);
    const cp1Y = R(sY + drop * lerp(0.20, 0.50, t('s6')));
    const cp2Y = R(sY + drop * lerp(0.50, 0.90, t('s6')));
    return `M ${sX},${sY} C ${cp1X},${cp1Y} ${cp2X},${cp2Y} ${eX},${eY}`;
  }

  function lifePath() {
    const sX = 195;
    const sY = R(lerp(494, 374, lerp(0.14, 0.70, 1 - t('s7'))));
    const eX = R(lerp(242, 422, t('s9')));
    const eY = 720;
    const b  = t('s8');
    const pH = eY - sY;
    const cp1X = R(lerp(262, 382, b));
    const cp1Y = R(sY + pH * lerp(0.25, 0.20, b));
    const cp2Offset = t('s9') < 0.5
      ? lerp(120, 0, t('s9') * 2)
      : lerp(0, -80, (t('s9') - 0.5) * 2);
    const cp2X = R(eX + cp2Offset);
    const cp2Y = R(sY + pH * lerp(0.65, 0.70, b));
    return `M ${sX},${sY} C ${cp1X},${cp1Y} ${cp2X},${cp2Y} ${eX},${eY}`;
  }

  function update() {
    document.getElementById('heart-line').setAttribute('d', heartPath());
    document.getElementById('head-line').setAttribute('d', headPath());
    document.getElementById('life-line').setAttribute('d', lifePath());
    const mp = morphPath(t('s10'), lerp(0.97, 1.18, t('s11')));
    document.getElementById('hand-path').setAttribute('d', mp);
    document.getElementById('hand-glow').setAttribute('d', mp);
    document.querySelector('.ssw-palm-svg').style.transform = '';
    IDS.forEach((id, i) => {
      document.getElementById('v' + (i + 1)).textContent = sliders[id].value;
    });
  }

  IDS.forEach(id => sliders[id].addEventListener('input', update));

  document.getElementById('reset-btn').addEventListener('click', () => {
    IDS.forEach(id => { sliders[id].value = 50; });
    update();
  });

  /* ─── Diagnosis (Light Mode Matched) ─── */
  const RESULT_DATA = [
    { id: 's1',  l: '内面を重視する内向タイプ',       r: '人との関わりを好む外向タイプ',       c: '#d9467d' },
    { id: 's2',  l: '感情をコントロールする冷静派',    r: '感情豊かな情熱家',                 c: '#d9467d' },
    { id: 's3',  l: '控えめで穏やかな愛情表現',       r: 'ストレートで積極的な愛情表現',       c: '#d9467d' },
    { id: 's4',  l: '石橋を叩いて渡る慎重派',         r: '直感で動く行動派',                 c: '#2b6cb0' },
    { id: 's5',  l: '瞬時に決める直感・回転型',       r: 'じっくり熟考する論理・長考型',       c: '#2b6cb0' },
    { id: 's6',  l: '想像力豊かなロマンチスト',       r: '実務能力に長けたリアリスト',         c: '#2b6cb0' },
    { id: 's7',  l: '落ち着きがあり安定を好む',       r: 'エネルギッシュな衝動派',             c: 'var(--color-primary)' },
    { id: 's8',  l: '自分のペースを守る省エネ型',     r: 'バイタリティ溢れる活動家',           c: 'var(--color-primary)' },
    { id: 's9',  l: '一つの場所で輝く定住志向',       r: '環境の変化を楽しむ変化志向',         c: 'var(--color-primary)' },
    { id: 's10', l: '地に足のついた現実志向',         r: '感性を重んじる精神志向',             c: '#d97706' },
    { id: 's11', l: '自分の感覚を信じる主観派',       r: '客観的データを重んじる論理派',       c: '#d97706' },
  ];

  const SPIDER_LABELS = [
    ['内向', '外向'], ['冷静', '情熱'], ['穏やか', '積極的'],
    ['慎重', '行動派'], ['回転型', '長考型'], ['ロマンチスト', 'リアリスト'],
    ['安定', '衝動'], ['省エネ', '活動家'], ['定住', '変化'],
    ['現実', '精神'], ['主観', '客観'],
  ];

  function buildSpider(vals) {
    const N = vals.length;
    const W = 560, H = 560, CX = 280, CY = 280;
    const SR = 165, LR = 213;
    const angle = i => (2 * Math.PI * i / N) - Math.PI / 2;
    // ライトモード用に色を調整
    const dotColors = ['#d9467d','#d9467d','#d9467d','#2b6cb0','#2b6cb0','#2b6cb0','#4e7b67','#4e7b67','#4e7b67','#d97706','#d97706'];

    let s = `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg">`;
    [0.25, 0.5, 0.75, 1.0].forEach(f => {
      const dash = f === 0.5 ? 'stroke-dasharray="5,4" stroke="rgba(0,0,0,0.15)" stroke-width="1.5"'
                             : 'stroke="rgba(0,0,0,0.06)" stroke-width="1"';
      s += `<circle cx="${CX}" cy="${CY}" r="${(SR*f).toFixed(1)}" fill="none" ${dash}/>`;
    });
    for (let i = 0; i < N; i++) {
      const ca = Math.cos(angle(i)), sa = Math.sin(angle(i));
      s += `<line x1="${(CX-SR*ca).toFixed(1)}" y1="${(CY-SR*sa).toFixed(1)}" x2="${(CX+SR*ca).toFixed(1)}" y2="${(CY+SR*sa).toFixed(1)}" stroke="rgba(0,0,0,0.08)" stroke-width="1"/>`;
    }
    vals.forEach((v, i) => {
      const ca = Math.cos(angle(i)), sa = Math.sin(angle(i));
      const posFrac = v / 100, negFrac = (100 - v) / 100;
      const px = (CX + SR * posFrac * ca).toFixed(1);
      const py = (CY + SR * posFrac * sa).toFixed(1);
      const nx = (CX - SR * negFrac * ca).toFixed(1);
      const ny = (CY - SR * negFrac * sa).toFixed(1);
      s += `<line x1="${nx}" y1="${ny}" x2="${px}" y2="${py}" stroke="${dotColors[i]}" stroke-width="1.8" opacity="0.6"/>`;
      s += `<circle cx="${px}" cy="${py}" r="5" fill="${dotColors[i]}" stroke="#fff" stroke-width="1.5"/>`;
      s += `<circle cx="${nx}" cy="${ny}" r="4" fill="${dotColors[i]}" stroke="#fff" stroke-width="1.2" opacity="0.7"/>`;
      const lx = (CX - LR*ca).toFixed(1), ly = (CY - LR*sa).toFixed(1);
      const lanchor = ca > 0.15 ? 'end' : ca < -0.15 ? 'start' : 'middle';
      const rx = (CX + LR*ca).toFixed(1), ry = (CY + LR*sa).toFixed(1);
      const ranchor = ca > 0.15 ? 'start' : ca < -0.15 ? 'end' : 'middle';
      s += `<text x="${lx}" y="${ly}" text-anchor="${lanchor}" dominant-baseline="middle" fill="var(--color-text)" font-weight="600" font-size="12" opacity="0.8">${SPIDER_LABELS[i][0]}</text>`;
      s += `<text x="${rx}" y="${ry}" text-anchor="${ranchor}" dominant-baseline="middle" fill="var(--color-text)" font-weight="600" font-size="12" opacity="0.8">${SPIDER_LABELS[i][1]}</text>`;
    });
    s += `<circle cx="${CX}" cy="${CY}" r="3.5" fill="rgba(0,0,0,0.2)"/>`;
    s += `</svg>`;
    return s;
  }

  function buildBipolarSvg(vals) {
    const W = 600, rowH = 38;
    const H = RESULT_DATA.length * rowH + 40;
    const CX = W / 2, trackW = 180, trackLeft = CX - trackW / 2;
    let s = `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg" style="width:100%;max-width:600px;height:auto;display:block;margin:0 auto;">`;
    RESULT_DATA.forEach((item, i) => {
      const val = vals[i], y = 30 + i * rowH;
      s += `<text x="${trackLeft - 15}" y="${y + 4}" text-anchor="end" fill="var(--color-text)" font-size="13" font-weight="600">${item.l}</text>`;
      s += `<text x="${trackLeft + trackW + 15}" y="${y + 4}" text-anchor="start" fill="var(--color-text)" font-size="13" font-weight="600">${item.r}</text>`;
      s += `<rect x="${trackLeft}" y="${y - 2}" width="${trackW}" height="4" rx="2" fill="rgba(0,0,0,0.06)"/>`;
      s += `<line x1="${CX}" y1="${y - 6}" x2="${CX}" y2="${y + 6}" stroke="rgba(0,0,0,0.15)" stroke-width="2"/>`;
      const dotX = trackLeft + (val / 100) * trackW;
      s += `<circle cx="${dotX}" cy="${y}" r="12" fill="${item.c}" opacity="0.15"/>`;
      s += `<circle cx="${dotX}" cy="${y}" r="6" fill="${item.c}" stroke="#ffffff" stroke-width="1.5"/>`;
    });
    s += `</svg>`;
    return s;
  }

  function buildQuadrant(posX, posY) {
    const W = 380, H = 380, CX = 190, CY = 190, QR = 145;
    const dx = (CX + posX / 50 * QR).toFixed(1);
    const dy = (CY - posY / 50 * QR).toFixed(1);
    const qColor = (posX >= 0 && posY >= 0) ? '#d9467d' :
                   (posX <  0 && posY >= 0) ? '#2b6cb0' :
                   (posX <  0 && posY <  0) ? '#4e7b67' : '#d97706';
    let s = `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg">`;
    ['0.25','0.5','0.75'].forEach(f => {
      s += `<circle cx="${CX}" cy="${CY}" r="${(QR * f).toFixed(1)}" fill="none" stroke="rgba(0,0,0,0.05)" stroke-width="1"/>`;
    });
    s += `<circle cx="${CX}" cy="${CY}" r="${QR}" fill="none" stroke="rgba(0,0,0,0.1)" stroke-width="1.2"/>`;
    s += `<line x1="${CX-QR}" y1="${CY}" x2="${CX+QR}" y2="${CY}" stroke="rgba(0,0,0,0.15)" stroke-width="1.2"/>`;
    s += `<line x1="${CX}" y1="${CY-QR}" x2="${CX}" y2="${CY+QR}" stroke="rgba(0,0,0,0.15)" stroke-width="1.2"/>`;
    const ql = [
      { x: CX+QR-6, y: CY-QR+14, anchor: 'end',   t: 'Visionary', col: '#d9467d' },
      { x: CX-QR+6, y: CY-QR+14, anchor: 'start', t: 'Creator',   col: '#2b6cb0' },
      { x: CX-QR+6, y: CY+QR-8,  anchor: 'start', t: 'Analyst',   col: '#4e7b67' },
      { x: CX+QR-6, y: CY+QR-8,  anchor: 'end',   t: 'Promoter',  col: '#d97706' },
    ];
    ql.forEach(q => {
      s += `<text x="${q.x}" y="${q.y}" text-anchor="${q.anchor}" fill="${q.col}" font-size="11" opacity="0.8" font-weight="700">${q.t}</text>`;
    });
    s += `<text x="${CX}" y="${CY-QR-10}" text-anchor="middle" fill="var(--color-text)" font-size="10" opacity="0.6">精神的・直感</text>`;
    s += `<text x="${CX}" y="${CY+QR+18}" text-anchor="middle" fill="var(--color-text)" font-size="10" opacity="0.6">現実的・論理</text>`;
    s += `<text x="${CX+QR+6}" y="${CY+4}" text-anchor="start" fill="var(--color-text)" font-size="10" opacity="0.6">動的</text>`;
    s += `<text x="${CX-QR-6}" y="${CY+4}" text-anchor="end"   fill="var(--color-text)" font-size="10" opacity="0.6">静的</text>`;
    s += `<line x1="${CX}" y1="${CY}" x2="${dx}" y2="${dy}" stroke="${qColor}" stroke-width="1.2" opacity="0.6" stroke-dasharray="4,3"/>`;
    s += `<circle cx="${dx}" cy="${dy}" r="10" fill="${qColor}" opacity="0.25"/>`;
    s += `<circle cx="${dx}" cy="${dy}" r="6" fill="${qColor}" stroke="#fff" stroke-width="1.8"/>`;
    s += `</svg>`;
    return s;
  }

  document.getElementById('diagnose-btn').addEventListener('click', () => {
    const vals = RESULT_DATA.map(item => Number(document.getElementById(item.id).value));
    const chartSvg   = buildSpider(vals);
    const bipolarSvg = buildBipolarSvg(vals);

    const [v1,v2,v3,v4,v5,v6,v7,v8,v9,v10,v11] = vals;
    const x_avg = (v1 + v3 + v4 + v7 + v8 + v9) / 6;
    const y_avg = (v2 + (100 - v5) + (100 - v6) + v10 + (100 - v11)) / 5;
    const posX = x_avg - 50, posY = y_avg - 50;

    let typeName, typeDesc;
    if      (posX >= 0 && posY >= 0) { typeName = '情熱のビジョナリー (Visionary)'; typeDesc = '豊かな感情と行動力を併せ持つ開拓者。共感と理想で周囲を巻き込みます。'; }
    else if (posX <  0 && posY >= 0) { typeName = '探求のクリエイター (Creator)';   typeDesc = '独自の感性と内省的な精神を持つ芸術家・参謀。深く狭く本質を追求します。'; }
    else if (posX <  0 && posY <  0) { typeName = '堅実なアナリスト (Analyst)';     typeDesc = 'データや事実を重んじ、慎重に行動する専門家。確実性と論理性を武器にします。'; }
    else                             { typeName = '結果のプロモーター (Promoter)';  typeDesc = '現実的な視点と高い行動力を持つ実務家。合理的に目標を達成しにいきます。'; }

    const quadSvg = buildQuadrant(posX, posY);

    let textHeart = 'あなたは、';
    if      (v1 >= 60) textHeart += '人との関わりを好む外向的な性質を持ちながら、';
    else if (v1 <= 40) textHeart += '自身の内面とじっくり向き合うことを大切にしながら、';
    else               textHeart += '状況に応じて人との距離感を柔軟に保ちながら、';
    if      (v2 >= 60) textHeart += '豊かな感情表現で周囲を惹きつける情熱的な一面があります。';
    else if (v2 <= 40) textHeart += '感情をしっかりコントロールし、常に冷静な対応ができる落ち着きを持っています。';
    else               textHeart += '感情の波が少なく、穏やかなコミュニケーションを築くことができます。';

    let textHead = '思考や仕事の面では、';
    if      (v4 >= 60) textHead += '直感を信じて素早く行動に移すフットワークの軽さを持ち、';
    else if (v4 <= 40) textHead += '石橋を叩いて渡る慎重さと計画性を持ち、';
    else               textHead += '周囲の状況をよく見てから的確なタイミングで動き出し、';
    if      (v5 >= 60) textHead += '物事を論理的に深く掘り下げる熟考型のアプローチを得意とします。';
    else if (v5 <= 40) textHead += '瞬時の判断力と頭の回転の速さを活かして次々と課題を処理していきます。';
    else               textHead += '直感と論理をバランス良く使い分け、柔軟に最適解を導き出します。';

    let textLife = 'ライフスタイルとしては、';
    if      (v9 >= 60) textLife += '環境の変化や新しい刺激を楽しみながら、';
    else if (v9 <= 40) textLife += 'ひとつの場所や安定した環境に根を下ろし、';
    else               textLife += '日常の中に適度な変化を取り入れながら、';
    if      (v8 >= 60) textLife += 'バイタリティ溢れる活動的な日々を送る傾向があります。';
    else if (v8 <= 40) textLife += '自分のペースを守り、無理のない範囲で着実にエネルギーを注ぐことを好みます。';
    else               textLife += 'オンとオフの切り替えを大切にして、安定したエネルギーで過ごすタイプです。';

    const summaryHtml = `
      <div class="result-section">
        <h3 class="result-heading">総合所見</h3>
        <div class="summary-box">
          <p>${textHeart}</p>
          <p>${textHead}</p>
          <p>${textLife}</p>
        </div>
      </div>`;

    const intanRatio = v10 / 100, tanRatio = 1 - intanRatio;
    const infoRatio  = v11 / 100, subjRatio = 1 - infoRatio;
    const pctFire  = intanRatio * subjRatio * 100;
    const pctWater = intanRatio * infoRatio * 100;
    const pctEarth = tanRatio   * subjRatio * 100;
    const pctWind  = tanRatio   * infoRatio * 100;
    const stop1 = pctFire.toFixed(2);
    const stop2 = (pctFire + pctWater).toFixed(2);
    const stop3 = (pctFire + pctWater + pctEarth).toFixed(2);

    const elements = [
      { name: '火', emoji: '🔥', pct: pctFire,  color: '#d9467d', desc: '無形×主観' },
      { name: '水', emoji: '💧', pct: pctWater, color: '#2b6cb0', desc: '無形×情報' },
      { name: '地', emoji: '🌿', pct: pctEarth, color: '#d97706', desc: '有形×主観' },
      { name: '風', emoji: '🌀', pct: pctWind,  color: '#4e7b67', desc: '有形×情報' },
    ];
    const dominant = elements.reduce((a, b) => a.pct >= b.pct ? a : b);

    const donutHtml = `
      <div class="result-section">
        <h3 class="result-heading">土台となる気質（手形の4属性）</h3>
        <div class="allocation-chart-container">
          <div class="donut-chart" style="background:conic-gradient(#d9467d 0% ${stop1}%,#2b6cb0 ${stop1}% ${stop2}%,#d97706 ${stop2}% ${stop3}%,#4e7b67 ${stop3}% 100%);">
            <div class="donut-inner"><span class="donut-total">BASE<br>NATURE</span></div>
          </div>
          <div class="stat-labels">
            <div class="stat-lbl"><span style="color:#d9467d; font-size:1.2em;">●</span> 【火】無形×主観: ${pctFire.toFixed(1)}%</div>
            <div class="stat-lbl"><span style="color:#2b6cb0; font-size:1.2em;">●</span> 【水】無形×情報: ${pctWater.toFixed(1)}%</div>
            <div class="stat-lbl"><span style="color:#d97706; font-size:1.2em;">●</span> 【地】有形×主観: ${pctEarth.toFixed(1)}%</div>
            <div class="stat-lbl"><span style="color:#4e7b67; font-size:1.2em;">●</span> 【風】有形×情報: ${pctWind.toFixed(1)}%</div>
          </div>
        </div>
        <div style="margin-top:1.2rem;padding:1.5rem;background:var(--color-bg);border:1px solid #d1e0d7;border-radius:12px;text-align:center;">
          <div style="font-size:0.75rem;color:#7a9487;letter-spacing:0.12em;margin-bottom:0.4rem;font-weight:bold;">最優位属性</div>
          <div style="font-size:2.2rem;line-height:1;">${dominant.emoji}</div>
          <div style="font-size:1.15rem;font-weight:700;color:${dominant.color};margin:0.5rem 0 0.2rem;letter-spacing:0.06em;">【${dominant.name}】${dominant.desc}</div>
          <div style="font-size:0.8rem;color:var(--color-text);opacity:0.8;">${dominant.pct.toFixed(1)}% — 最も強く現れる気質</div>
        </div>
      </div>`;

    document.getElementById('ssw-result-body').innerHTML =
      summaryHtml +
      `<div class="result-section">
         <h3 class="result-heading">分析パラメーター（対極バランス）</h3>
         <div style="margin:1.5rem 0 0;">${bipolarSvg}</div>
       </div>` +
      `<div class="spider-wrap">${chartSvg}</div>` +
      `<div class="quad-section">
         <h3 class="result-heading" style="border:none; margin-bottom:0.5rem;">性格マトリクス</h3>
         <div class="quad-wrap">${quadSvg}</div>
         <div class="type-card">
           <div class="type-name">${typeName}</div>
           <div class="type-desc">${typeDesc}</div>
         </div>
       </div>
       <div class="quad-section">${donutHtml}</div>`;

    document.getElementById('ssw-result-panel').classList.remove('ssw-result-hidden');
  });

  document.getElementById('result-close').addEventListener('click', () => {
    document.getElementById('ssw-result-panel').classList.add('ssw-result-hidden');
  });

  update();
})();
</script>