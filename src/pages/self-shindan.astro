  .ssw-ll .ssw-sval { color: var(--ssw-life); background: rgba(78,123,103,0.1); }

  .ssw-hd input[type=range] { background: rgba(217, 119, 6, 0.3); }
  .ssw-hd input[type=range]::-webkit-slider-thumb {
    background: var(--ssw-hand);
    box-shadow: 0 0 0 4px rgba(217, 119, 6, 0.2), 0 2px 6px rgba(217, 119, 6, 0.4);
  }
  .ssw-hd .ssw-sval { color: var(--ssw-hand); background: rgba(217,119,6,0.1); }

  /* Reset button */
  .ssw-reset-btn {
    display: block; width: 100%; margin-top: 1.25rem;
    padding: 0.6rem 1rem; 
    background-color: #ffffff; 
    border-radius: 12px; 
    border: 1px solid #e1ebe5; 
    box-shadow: 0 4px 0 #d1e0d7, 0 5px 10px rgba(78, 123, 103, 0.06);
    color: var(--ssw-muted); font-size: 0.8rem; font-weight: bold; letter-spacing: 0.06em;
    cursor: pointer; transition: all 0.2s ease;
    font-family: inherit;
  }
  .ssw-reset-btn:hover { 
    color: var(--color-primary); transform: translateY(-2px); 
    box-shadow: 0 6px 0 #d1e0d7, 0 8px 15px rgba(78, 123, 103, 0.12); 
  }
  .ssw-reset-btn:active { transform: translateY(4px); box-shadow: 0 0 0 transparent; }

  /* ── タブ切替 ── */
  .ssw-tabs {
    display: flex;
    gap: 6px;
    margin-bottom: 10px;
    background: rgba(78, 123, 103, 0.07);
    border-radius: 12px;
    padding: 4px;
  }
  .ssw-tab {
    flex: 1;
    padding: 9px 0;
    border: none;
    border-radius: 9px;
    font-size: 0.88rem;
    font-weight: bold;
    font-family: inherit;
    cursor: pointer;
    background: transparent;
    color: var(--color-text);
    opacity: 0.55;
    transition: background 0.18s, opacity 0.18s, box-shadow 0.18s;
  }
  .ssw-tab.active {
    background: #ffffff;
    opacity: 1;
    box-shadow: 0 2px 8px rgba(78, 123, 103, 0.18);
    color: var(--color-primary);
  }

  /* ── URL共有ボタン ── */
  .ssw-share-wrap {
    margin-bottom: 14px;
  }
  .ssw-url-share-btn {
    display: block;
    width: 100%;
    padding: 9px 12px;
    background: transparent;
    border: 1.5px dashed rgba(78, 123, 103, 0.5);
    border-radius: 9px;
    color: var(--color-primary);
    font-size: 0.8rem;
    font-weight: bold;
    font-family: inherit;
    cursor: pointer;
    text-align: center;
    transition: background 0.18s, border-color 0.18s;
  }
  .ssw-url-share-btn:hover {
    background: rgba(78, 123, 103, 0.08);
    border-color: var(--color-primary);
  }

  /* Diagnose button */
  .ssw-diagnose-btn {
    display: block; width: 100%; margin-top: 0.85rem;
    padding: 0.85rem 1rem;
    background: var(--color-primary);
    border: none;
    border-radius: 12px;
    color: #ffffff; font-size: 0.9rem; font-weight: bold;
    letter-spacing: 0.08em; cursor: pointer;
    box-shadow: 0 4px 0 var(--color-accent), 0 5px 10px rgba(78, 123, 103, 0.15);
    transition: all 0.2s ease;
    font-family: inherit;
  }
  .ssw-diagnose-btn:hover {
    background: #5a8a75;
    transform: translateY(-2px);
    box-shadow: 0 6px 0 var(--color-accent), 0 8px 15px rgba(78, 123, 103, 0.2);
  }
  .ssw-diagnose-btn:active { transform: translateY(4px); box-shadow: 0 0 0 transparent; }

  /* ── 相性診断専用スコア表示 ── */
  .pair-score-wrap { text-align: center; margin: 1rem 0 2rem; background: rgba(78, 123, 103, 0.05); border: 1px solid #d1e0d7; border-radius: 16px; padding: 2rem 1rem; }
  .pair-score-num { font-size: 4.5rem; font-weight: 800; color: var(--color-primary); line-height: 1; margin: 0.5rem 0; font-family: system-ui; }
  .pair-score-label { font-size: 0.85rem; color: #7a9487; font-weight: bold; letter-spacing: 0.15em; }

  /* ── Preview Panel (PC Light Mode) ── */
  .ssw-preview {
    background: #ffffff;
    border: 1px solid var(--ssw-border);
    border-radius: 18px;
    padding: 1.5rem;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    min-height: 520px;
    position: relative; overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }

  .ssw-palm-svg {
    width: 100%; max-width: 420px; height: auto;
    overflow: visible; transform-origin: 50% 100%;
    transition: transform 0.25s ease;
  }

  /* SVG hand / lines */
  #hand-path {
    fill: rgba(242, 246, 244, 0.8);
    stroke: var(--color-text);
    stroke-width: 2.2;
    stroke-linejoin: round;
    stroke-linecap: round;
  }
  #heart-line {
    fill: none; stroke: var(--ssw-heart); stroke-width: 2.8; stroke-linecap: round;
    filter: drop-shadow(0 0 3px rgba(217,70,125,0.3));
  }
  #head-line {
    fill: none; stroke: var(--ssw-head); stroke-width: 2.8; stroke-linecap: round;
    filter: drop-shadow(0 0 3px rgba(43,108,176,0.3));
  }
  #life-line {
    fill: none; stroke: var(--ssw-life); stroke-width: 2.8; stroke-linecap: round;
    filter: drop-shadow(0 0 3px rgba(78,123,103,0.3));
