    const yVals = RESULT_DATA.map(item => Number(y[item.id]));
    const pVals = RESULT_DATA.map(item => Number(p[item.id]));

    const yX = ((y.s1 + y.s3 + y.s4 + y.s7 + y.s8 + y.s9) / 6) - 50;
    const yY = ((y.s2 + (100 - y.s5) + (100 - y.s6) + y.s10 + (100 - y.s11)) / 5) - 50;
    const pX = ((p.s1 + p.s3 + p.s4 + p.s7 + p.s8 + p.s9) / 6) - 50;
    const pY = ((p.s2 + (100 - p.s5) + (100 - p.s6) + p.s10 + (100 - p.s11)) / 5) - 50;

    const pairBipolarSvg = buildPairBipolarSvg(yVals, pVals);
    const pairQuadSvg = buildPairQuadrant(yX, yY, pX, pY);

    let pairHtml = `
      <div class="result-section">
        <div class="pair-score-wrap">
          <div class="pair-score-label">長期的なパートナーシップ相性</div>
          <div class="pair-score-num">${score}<span style="font-size:1.5rem;">%</span></div>
          <p style="font-size:0.8rem; color:#7a9487; margin-top:0.5rem; line-height:1.5;">※このスコアはお互いの価値観の共有度と、一緒にいる際の「不快感の少なさ」を表しています。</p>
        </div>
        <h3 class="result-heading">感情・コミュニケーション</h3>
        <div class="summary-box"><p>${textHeart}</p></div>
        <h3 class="result-heading">思考・価値観</h3>
        <div class="summary-box"><p>${textHead}</p></div>
        <h3 class="result-heading">ライフスタイル・活動</h3>
        <div class="summary-box"><p>${textLife}</p></div>
      </div>
    `;

    pairHtml += `
      <div class="result-section">
        <h3 class="result-heading">価値観のギャップ分析</h3>
        <p style="font-size:0.8rem; color:#7a9487; text-align:center; margin-bottom:1rem;">太い線が短いほど価値観が似ており、長いほどギャップがあります。</p>
        <div style="margin:1.5rem 0 0;">${pairBipolarSvg}</div>
      </div>
      <div class="quad-section">
        <h3 class="result-heading" style="border:none; margin-bottom:0.5rem;">二人の性格ポジション</h3>
        <p style="font-size:0.8rem; color:#7a9487; text-align:center; margin-bottom:1rem;">距離が近いほど似た者同士、遠いほど異なる役割を持っています。</p>
        <div class="quad-wrap">${pairQuadSvg}</div>
      </div>
    `;

    document.getElementById('ssw-result-body').innerHTML = pairHtml;
    document.querySelector('.ssw-result-title').textContent = "二人の相性診断レポート";
    document.querySelector('.ssw-result-sub').textContent = "手相の差分から読み解く、二人が長く一緒にいるための取扱説明書です。";
    document.getElementById('ssw-result-panel').classList.remove('ssw-result-hidden');
  });

  document.getElementById('result-close').addEventListener('click', () => {
    document.getElementById('ssw-result-panel').classList.add('ssw-result-hidden');
  });

  // ── URL生成：自分のデータを ?p= パラメータにエンコードしてコピー ──
  document.getElementById('share-btn').addEventListener('click', () => {
    const encoded = IDS.map(id => state.you[id]).join('-');
    const url = location.origin + location.pathname + '?p=' + encoded;
    navigator.clipboard.writeText(url).then(() => {
      const btn = document.getElementById('share-btn');
      const orig = btn.textContent;
      btn.textContent = 'コピーしました！✅';
      setTimeout(() => { btn.textContent = orig; }, 2500);
    }).catch(() => {
      prompt('このURLをコピーしてください', url);
    });
  });

  // ── URL読み込み：?p= があれば partner に読み込み、you タブで開始 ──
  (function loadFromUrl() {
    const params = new URLSearchParams(location.search);
    const p = params.get('p');
    if (!p) return;
    const nums = p.split('-').map(n => {
      const v = parseInt(n, 10);
      return isNaN(v) ? 50 : Math.min(100, Math.max(0, v));
    });
    if (nums.length !== IDS.length) return;
    IDS.forEach((id, i) => { state.partner[id] = nums[i]; });
    // 相手のデータを読み込んだので you タブで開始（ユーザーが自分を入力できる状態）
    switchTab('you');
  })();

  update();
})();
</script>