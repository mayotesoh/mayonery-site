    -webkit-appearance: none;
    width: 100%; height: 6px; border-radius: 3px; outline: none; cursor: pointer;
  }
  .ssw input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 28px; height: 28px; border-radius: 50%;
    border: 3px solid #ffffff;
    cursor: grab;
    transition: transform 0.12s, box-shadow 0.12s;
  }
  .ssw input[type=range]::-webkit-slider-thumb:active { cursor: grabbing; transform: scale(1.15); }
  .ssw input[type=range]::-moz-range-track { height: 6px; border-radius: 3px; border: none; }
  .ssw input[type=range]::-moz-range-thumb {
