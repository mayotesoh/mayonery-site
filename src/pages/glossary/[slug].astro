---
import Layout from '../../layouts/Layout.astro';

interface Props {
  term: any;
}

export async function getStaticPaths() {
  const apiKey = import.meta.env.NOTION_API_KEY;
  const glossaryId = import.meta.env.NOTION_GLOSSARY_ID;

  const response = await fetch(`https://api.notion.com/v1/databases/${glossaryId}/query`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${apiKey}`,
      'Notion-Version': '2022-06-28',
      'Content-Type': 'application/json',
    },
  });
  
  const data = await response.json();
  const terms = data.results || [];

  return terms.map((term: any) => {
    // URLスラッグを取得。なければIDをURLにする
    const slug = term.properties['URLスラッグ']?.rich_text?.[0]?.plain_text || term.id;
    return {
      params: { slug: slug },
      props: { term: term },
    };
  });
}

const { term } = Astro.props;
if (!term) return Astro.redirect('/404');

// プロパティの取得
const name = term.properties['名前']?.title?.[0]?.plain_text || '無題';
const reading = term.properties['読み']?.rich_text?.[0]?.plain_text || '';
const catObj = term.properties['カテゴリー']?.select?.name || term.properties['カテゴリー']?.multi_select?.[0]?.name;
const category = catObj || '未分類';
const meaning = term.properties['意味']?.rich_text?.[0]?.plain_text || '';

// 🌟 本文（ブロック）の取得
const apiKey = import.meta.env.NOTION_API_KEY;
const blocksResponse = await fetch(`https://api.notion.com/v1/blocks/${term.id}/children?page_size=100`, {
  headers: {
    'Authorization': `Bearer ${apiKey}`,
    'Notion-Version': '2022-06-28',
  },
});
const blocksData = await blocksResponse.json();
const blocks = blocksData.results || [];
---

<Layout title={`${name} | 手相用語集`}>
    <article class="glossary-detail-container">
        
        <div class="back-link-top">
            <a href="/glossary" class="btn-text">← 用語集一覧へ戻る</a>
        </div>

        <header class="term-header-detail">
            <div class="term-meta">
                <span class="category-tag">{category}</span>
                <span class="reading">{reading}</span>
            </div>
            <h1 class="term-title">{name}</h1>
            {meaning && <div class="term-summary-box"><p>{meaning}</p></div>}
        </header>

        <div class="post-content">
            {blocks.length > 0 ? (
                blocks.map((block: any) => {
                    if (block.type === 'paragraph') {
                        const text = block.paragraph.rich_text.map((t:any) => {
                            if(t.href) return `<a href="${t.href}" target="_blank">${t.plain_text}</a>`;
                            return t.plain_text;
                        }).join('');
                        return <p set:html={text || '<br/>'}></p>;
                    }
                    if (block.type === 'heading_2') {
                        const text = block.heading_2.rich_text.map((t:any) => t.plain_text).join('');
                        return <h2>{text}</h2>;
                    }
                    if (block.type === 'heading_3') {
                        const text = block.heading_3.rich_text.map((t:any) => t.plain_text).join('');
                        return <h3>{text}</h3>;
                    }
                    if (block.type === 'bulleted_list_item') {
                         const text = block.bulleted_list_item.rich_text.map((t:any) => t.plain_text).join('');
                         return <li class="bullet-list">・ {text}</li>;
                    }
                    if (block.type === 'image') {
                        const imageUrl = block.image.type === 'external' ? block.image.external.url : block.image.file.url;
                        return <img src={imageUrl} alt={`${name}の図解`} class="post-image" loading="lazy" />;
                    }
                    if (block.type === 'callout') {
                         const icon = block.callout.icon?.emoji || '💡';
                         const text = block.callout.rich_text.map((t:any) => t.plain_text).join('');
                         return <div class="callout-box"><span class="callout-icon">{icon}</span><p>{text}</p></div>;
                    }
                    return null;
                })
            ) : (
                <div class="empty-content-msg">
                    <p>この用語の詳しい解説は現在準備中です。</p>
                </div>
            )}
        </div>
        
    </article>
</Layout>

<style>
    .glossary-detail-container { max-width: 800px; margin: 0 auto; padding: 40px 20px 80px; }
    
    .back-link-top { margin-bottom: 30px; }
    .btn-text { color: var(--color-primary); text-decoration: none; font-weight: bold; transition: color 0.2s; }
    .btn-text:hover { color: var(--color-accent); text-decoration: underline; }

    .term-header-detail { margin-bottom: 40px; }
    .term-meta { display: flex; align-items: center; gap: 15px; margin-bottom: 10px; }
    .category-tag { background: var(--color-primary); color: white; padding: 4px 12px; border-radius: 4px; font-size: 0.85rem; font-weight: bold; }
    .reading { color: #666; font-size: 1rem; }
    
    .term-title { font-size: 2.5rem; color: var(--color-text); margin: 0 0 20px 0; border-bottom: 2px solid var(--color-primary); padding-bottom: 15px; }
    
    .term-summary-box { background-color: var(--color-bg); border-left: 4px solid var(--color-accent); padding: 15px 20px; border-radius: 0 8px 8px 0; margin-bottom: 30px;}
    .term-summary-box p { margin: 0; font-weight: bold; color: var(--color-text); font-size: 1.1rem; line-height: 1.5; }

    .post-content { font-size: 1.1rem; line-height: 1.8; color: var(--color-text); }
    .post-content p { margin-bottom: 1.5em; }
    .post-content a { color: var(--color-accent); text-decoration: underline; }
    .post-content h2 { font-size: 1.6rem; color: var(--color-primary); margin-top: 2.5em; margin-bottom: 1em; padding-left: 10px; border-left: 5px solid var(--color-primary); }
    .post-content h3 { font-size: 1.3rem; margin: 1.5em 0 0.8em; font-weight: bold; border-bottom: 1px dashed #ccc; padding-bottom: 5px; }
    .bullet-list { margin-left: 1.2em; margin-bottom: 0.5em; list-style: none; }
    .post-image { max-width: 100%; height: auto; border-radius: 8px; margin: 2em auto; display: block; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
    
    .callout-box { display: flex; background: #fff; padding: 20px; border-radius: 8px; margin: 2em 0; border: 1px solid var(--color-primary); box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
    .callout-icon { font-size: 1.5rem; margin-right: 15px; }

    .empty-content-msg { text-align: center; padding: 40px; color: #888; background-color: #fafafa; border-radius: 8px; border: 1px dashed #ccc;}
</style>