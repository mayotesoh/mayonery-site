---
import Layout from '../layouts/Layout.astro';

const apiKey = import.meta.env.NOTION_API_KEY;
const databaseId = import.meta.env.NOTION_KOUZA_ID; 

let proPosts = [];
try {
    const response = await fetch(`https://api.notion.com/v1/databases/${databaseId}/query`, {
        method: 'POST',
        headers: {
            'Authorization': `Bearer ${apiKey}`,
            'Notion-Version': '2022-06-28',
            'Content-Type': 'application/json',
        },
    });
    const data = await response.json();
    const allPosts = data.results || [];

    // 🌟 「公開」かつ「レベルに『プロ』を含む」ものだけを抽出！
    proPosts = allPosts.filter((post: any) => {
        const status = post.properties['ステータス']?.status?.name || post.properties['ステータス']?.select?.name || '';
        const levels = post.properties['レベル']?.multi_select?.map((t: any) => t.name) || [];
        return status === '公開' && levels.includes('プロ');
    });
} catch(e) {
    console.error(e);
}
---

<Layout title="講師、占い師向け講座・添削サービス | 手相のマヨネリ">
    <div class="container page-container">
        <header class="page-header text-center">
            <h1 class="page-title">講師、占い師向け<br>講座・添削サービス</h1>
            <p class="page-desc">あなたの鑑定スキルと発信力を「論理的分析」でさらに高める、プロ専用のサポート環境です。</p>
        </header>

        <section class="intro-section">
            <p>鑑定結果がうまく言語化できない、お客様にどう伝えれば深く納得してもらえるか分からない…。<br>
            そんな同業者の方のために、論理的手相学の視点からあなたの鑑定を細かく添削・アドバイスし、ワンランク上のサービスを提供するための講座をご用意しました。</p>
        </section>

        <div class="kouza-grid">
            {proPosts.map((post: any) => {
                const title = post.properties['タイトル']?.title[0]?.plain_text || '無題';
                const summary = post.properties['概要']?.rich_text[0]?.plain_text || '';
                const price = post.properties['価格']?.rich_text[0]?.plain_text || post.properties['価格']?.number || '価格未定';
                const slug = post.properties['URLスラッグ']?.rich_text[0]?.plain_text || post.id;

                return (
                    <article class="kouza-card pro-card">
                        <div class="kouza-content">
                            <div class="kouza-meta">
                                <span class="tag-pro">PRO</span>
                                <span class="kouza-price">¥{price}</span>
                            </div>
                            <h2 class="kouza-title">{title}</h2>
                            <p class="kouza-summary">{summary}</p>
                            <div class="card-action">
                                <a href={`/kouza/${slug}`} class="btn-detail">詳細・お申し込み →</a>
                            </div>
                        </div>
                    </article>
                )
            })}
            
            {proPosts.length === 0 && (
                <div class="dummy-box">
                    <p>現在、プロ向けの講座・添削サービスを準備中です。<br>公開までもうしばらくお待ちください。</p>
                </div>
            )}
        </div>

        <div class="back-link">
            <a href="/service" class="btn-back">← サービス一覧に戻る</a>
        </div>
    </div>
</Layout>

<style>
    .page-container { padding: 60px 15px 80px; max-width: 900px; margin: 0 auto; }
    .text-center { text-align: center; }
    .page-header { margin-bottom: 40px; }
    .page-title { font-size: 2.2rem; color: #1e293b; margin-bottom: 15px; line-height: 1.4; }
    .page-desc { font-size: 1.1rem; color: #475569; font-weight: bold; }
    
    .intro-section { background: white; padding: 30px; border-radius: 12px; border-left: 4px solid var(--color-primary); margin-bottom: 50px; line-height: 1.8; color: #333; box-shadow: 0 4px 10px rgba(0,0,0,0.03); }
    
    .kouza-grid { display: flex; flex-direction: column; gap: 30px; margin-bottom: 60px; }
    
    /* プロ向けは少しシックで高級感のあるデザインに */
    .pro-card { background: #f8fafc; border: 1px solid #cbd5e1; border-radius: 16px; overflow: hidden; transition: transform 0.2s; }
    .pro-card:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08); border-color: #94a3b8; }
    .kouza-content { padding: 35px; }
    
    .kouza-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid #e2e8f0; padding-bottom: 15px; }
    .tag-pro { background: #1e293b; color: white; padding: 4px 15px; border-radius: 4px; font-size: 0.9rem; font-weight: bold; letter-spacing: 0.05em; }
    .kouza-price { font-size: 1.4rem; font-weight: bold; color: #0f172a; }
    
    .kouza-title { font-size: 1.5rem; color: #0f172a; margin-bottom: 15px; line-height: 1.4; }
    .kouza-summary { color: #475569; line-height: 1.7; margin-bottom: 25px; }
    
    .card-action { text-align: right; }
    .btn-detail { display: inline-block; background: #0f172a; color: white; padding: 14px 35px; border-radius: 8px; text-decoration: none; font-weight: bold; transition: opacity 0.2s; }
    .btn-detail:hover { opacity: 0.8; }
    
    .dummy-box { background: white; padding: 40px; border-radius: 12px; border: 1px dashed #cbd5e1; text-align: center; color: #64748b; }
    
    .back-link { text-align: center; }
    .btn-back { display: inline-block; padding: 12px 30px; background: white; color: var(--color-primary); text-decoration: none; border-radius: 30px; font-weight: bold; border: 1px solid var(--color-primary); transition: all 0.3s; }
    .btn-back:hover { background: var(--color-primary); color: white; }
</style>