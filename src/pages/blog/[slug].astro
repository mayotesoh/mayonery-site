---
import Layout from '../../layouts/Layout.astro';

const apiKey = import.meta.env.NOTION_API_KEY;
const databaseId = import.meta.env.NOTION_DATABASE_ID;

const response = await fetch(`https://api.notion.com/v1/databases/${databaseId}/query`, {
  method: 'POST',
  headers: {
    'Authorization': `Bearer ${apiKey}`,
    'Notion-Version': '2022-06-28',
    'Content-Type': 'application/json',
  },
});

const data = await response.json();
const allPosts = data.results || [];

// 💡 ステータスが「公開中」かつ、タグに「講座」が含まれない記事だけを抽出
const posts = allPosts.filter((post: any) => {
  const status = post.properties['ステータス']?.status?.name || post.properties['ステータス']?.select?.name || '';
  const tags = post.properties['タグ']?.multi_select?.map((t: any) => t.name) || [];
  
  const isPublished = status === '公開中';
  const isNotKouza = !tags.includes('講座');

  return isPublished && isNotKouza;
});

// フィルターボタン用のタグ一覧
const allTags = [...new Set(posts.flatMap((post: any) => post.properties['タグ']?.multi_select?.map((t: any) => t.name) || []))].filter(Boolean);
---

<Layout title="ブログ・思考録 | マヨネリ (Mayonery)">
    <section class="blog-container">
        <h1 class="page-title">ブログ・思考録</h1>
        <p class="page-desc">Notionに書き留めた手相の考察や、動画のまとめを公開しています。</p>

        <div class="search-and-filter-wrapper">
            <div class="search-input-container">
                <span class="search-icon">🔍</span>
                <input type="text" id="blog-search" placeholder="記事のタイトルやタグで検索..." autocomplete="off" />
            </div>
            <div class="filter-tags">
                <button class="filter-btn active" data-tag="all">すべて</button>
                {allTags.map(tag => ( <button class="filter-btn" data-tag={tag}>{tag}</button> ))}
            </div>
        </div>

        <div class="post-grid" id="post-grid">
            {posts.length > 0 ? (
                posts.map((post: any) => {
                    const title = post.properties['タイトル']?.title[0]?.plain_text || '（タイトルなし）';
                    const dateStr = post.properties['公開日']?.date?.start || '';
                    const date = dateStr ? new Date(dateStr).toLocaleDateString('ja-JP') : '未設定';
                    const tags = post.properties['タグ']?.multi_select?.map((t: any) => t.name) || [];
                    const tagsStr = tags.join(','); 
                    const slug = post.properties['URLスラッグ']?.rich_text[0]?.plain_text || post.id;

                    // 🌟 修正：Notionのプロパティ名「アイキャッチ」から画像を取得
                    const imageProp = post.properties['アイキャッチ']?.files?.[0];
                    let eyecatchUrl = '/favicon.png'; // 画像がない場合はマヨネリアイコンを代用
                    if (imageProp) {
                        eyecatchUrl = imageProp.type === 'file' ? imageProp.file.url : imageProp.external?.url;
                    }

                    return (
                        <a href={`/blog/${slug}`} class="post-link-wrapper" data-title={title} data-tags={tagsStr}>
                            <article class="post-card">
                                <img src={eyecatchUrl} alt="" class="post-card-bg" loading="lazy" />
                                
                                <div class="post-card-content">
                                    <div class="post-meta">
                                        <span class="post-date">📅 {date}</span>
                                        <div class="post-tags">
                                            {tags.map((tag: string) => ( <span class="tag">{tag}</span> ))}
                                        </div>
                                    </div>
                                    <h2 class="post-title">{title}</h2>
                                    <span class="read-more">記事を読む →</span>
                                </div>
                            </article>
                        </a>
                    )
                })
            ) : (
                <div class="empty-state"><p>現在、公開中の記事はありません。</p></div>
            )}
        </div>
        <div id="no-results" class="hidden"><p>該当する記事が見つかりませんでした。</p></div>
    </section>
</Layout>

<script>
    const searchInput = document.getElementById('blog-search') as HTMLInputElement;
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.post-link-wrapper');
    const noResults = document.getElementById('no-results');

    function filterPosts() {
        const query = searchInput.value.toLowerCase().trim();
        const activeBtn = document.querySelector('.filter-btn.active') as HTMLElement;
        const activeTag = activeBtn?.getAttribute('data-tag') || 'all';
        let visibleCount = 0;

        cards.forEach((card) => {
            const htmlCard = card as HTMLElement;
            const title = htmlCard.getAttribute('data-title')?.toLowerCase() || '';
            const tagsStr = htmlCard.getAttribute('data-tags')?.toLowerCase() || '';
            const tagsArray = htmlCard.getAttribute('data-tags')?.split(',') || [];
            const matchSearch = title.includes(query) || tagsStr.includes(query);
            const matchTag = activeTag === 'all' || tagsArray.includes(activeTag);

            if (matchSearch && matchTag) {
                htmlCard.style.display = 'block';
                visibleCount++;
            } else {
                htmlCard.style.display = 'none';
            }
        });

        if (visibleCount === 0) {
            noResults?.classList.remove('hidden');
        } else {
            noResults?.classList.add('hidden');
        }
    }
    searchInput.addEventListener('input', filterPosts);
    filterBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            filterBtns.forEach(b => b.classList.remove('active'));
            const target = e.currentTarget as HTMLElement;
            target.classList.add('active');
            filterPosts();
        });
    });
</script>

<style>
    .blog-container { max-width: 1000px; margin: 0 auto; padding: 40px 20px; }
    .page-title { color: var(--color-primary); font-size: 2.2rem; text-align: center; margin-bottom: 10px; }
    .page-desc { text-align: center; color: #666; margin-bottom: 30px; font-size: 1.1rem; }
    
    .search-and-filter-wrapper { background-color: var(--color-bg); padding: 20px 0; margin-bottom: 40px; position: sticky; top: 60px; z-index: 10; border-bottom: 1px dashed #ccc; }
    .search-input-container { position: relative; max-width: 600px; margin: 0 auto 20px; }
    .search-icon { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); font-size: 1.2rem; }
    #blog-search { width: 100%; box-sizing: border-box; padding: 12px 15px 12px 45px; border: 2px solid var(--color-primary); border-radius: 50px; font-size: 1.1rem; outline: none; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
    
    .filter-tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; max-width: 800px; margin: 0 auto; }
    .filter-btn { background-color: white; border: 1px solid #ccc; color: var(--color-text); padding: 6px 16px; border-radius: 20px; cursor: pointer; font-size: 0.9rem; transition: all 0.2s; }
    .filter-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }
    .filter-btn.active { background-color: var(--color-primary); color: white; border-color: var(--color-primary); font-weight: bold; }
    
    .post-link-wrapper { text-decoration: none; color: inherit; display: block; }
    .post-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 25px; }
    
    /* 🌟 サムネイルカードの新しいデザイン */
    .post-card { 
        position: relative;
        border-radius: 12px; 
        overflow: hidden;
        min-height: 280px; /* カードの高さ */
        display: flex;
        flex-direction: column;
        justify-content: flex-end; /* コンテンツを下寄せに */
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        border: 1px solid #e0e0e0;
        transition: transform 0.2s ease, box-shadow 0.2s ease; 
    }
    .post-link-wrapper:hover .post-card { 
        transform: translateY(-5px); 
        box-shadow: 0 10px 25px rgba(0,0,0,0.15); 
        border-color: var(--color-accent); 
    }

    /* 背景になるサムネイル画像 */
    .post-card-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 1;
        transition: transform 0.4s ease;
    }
    .post-link-wrapper:hover .post-card-bg {
        transform: scale(1.05); /* ホバーで画像が少しズーム */
    }

    /* 文字が乗る半透明の白背景 */
    .post-card-content {
        position: relative;
        z-index: 2;
        background-color: rgba(255, 255, 255, 0.85); /* 🌟 うっすら透過した白 */
        backdrop-filter: blur(4px); /* ぼかし効果でさらに読みやすく */
        padding: 20px;
        width: 100%;
        box-sizing: border-box;
        border-top: 1px solid rgba(255, 255, 255, 0.5);
    }

    .post-meta { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; font-size: 0.85rem; }
    .post-date { color: #555; font-weight: bold; }
    .post-tags { display: flex; flex-wrap: wrap; gap: 5px; justify-content: flex-end; }
    .tag { background: rgba(78, 123, 103, 0.15); color: var(--color-primary); padding: 3px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: bold;}
    
    .post-title { font-size: 1.25rem; color: var(--color-text); margin-bottom: 15px; line-height: 1.5; font-weight: bold;}
    .read-more { display: inline-block; font-size: 0.95rem; color: var(--color-accent); font-weight: bold; text-align: right; width: 100%; }
    
    .empty-state { grid-column: 1 / -1; text-align: center; padding: 50px; color: #777; background: #f9f9f9; border-radius: 10px; }
    .hidden { display: none !important; }
    #no-results { text-align: center; padding: 50px; color: #999; }
</style>