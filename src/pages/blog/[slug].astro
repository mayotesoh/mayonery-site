---
import Layout from '../../layouts/Layout.astro';

// 1. 全記事のURL（スラッグ）のリストを作る
export async function getStaticPaths() {
  const apiKey = import.meta.env.NOTION_API_KEY;
  const databaseId = import.meta.env.NOTION_DATABASE_ID;

  const response = await fetch(`https://api.notion.com/v1/databases/${databaseId}/query`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${apiKey}`,
      'Notion-Version': '2022-06-28',
      'Content-Type': 'application/json',
    },
  });
  const data = await response.json();
  const allPosts = data.results || [];

  return allPosts.map((post: any) => {
    const slug = post.properties['URLスラッグ']?.rich_text[0]?.plain_text || post.id;
    return {
      params: { slug: slug },
      props: { post: post },
    };
  });
}

const { post } = Astro.props;
const title = post.properties['タイトル']?.title[0]?.plain_text || '無題';
const dateStr = post.properties['公開日']?.date?.start || '';
const date = dateStr ? new Date(dateStr).toLocaleDateString('ja-JP') : '未設定';

// 3. NotionのAPIを叩いて「本文（ブロック）」を取得する
const apiKey = import.meta.env.NOTION_API_KEY;
const blocksResponse = await fetch(`https://api.notion.com/v1/blocks/${post.id}/children?page_size=100`, {
  headers: {
    'Authorization': `Bearer ${apiKey}`,
    'Notion-Version': '2022-06-28',
  },
});
const blocksData = await blocksResponse.json();
const blocks = blocksData.results || [];
---

<Layout title={`${title} | マヨネリブログ`}>
    <article class="single-post-container">
        <header class="post-header">
            <p class="post-date">公開日：{date}</p>
            <h1 class="post-title">{title}</h1>
        </header>

        <div class="post-content">
            {blocks.length > 0 ? (
                blocks.map((block: any) => {
                    // 段落
                    if (block.type === 'paragraph') {
                        const text = block.paragraph.rich_text.map((t:any) => {
                            // リンクが設定されていれば <a> タグにする
                            if(t.href) return `<a href="${t.href}" target="_blank">${t.plain_text}</a>`;
                            return t.plain_text;
                        }).join('');
                        return <p set:html={text || '<br/>'}></p>;
                    }
                    // 見出し2
                    if (block.type === 'heading_2') {
                        const text = block.heading_2.rich_text.map((t:any) => t.plain_text).join('');
                        return <h2>{text}</h2>;
                    }
                    // 見出し3
                    if (block.type === 'heading_3') {
                        const text = block.heading_3.rich_text.map((t:any) => t.plain_text).join('');
                        return <h3>{text}</h3>;
                    }
                    // 箇条書きリスト
                    if (block.type === 'bulleted_list_item') {
                         const text = block.bulleted_list_item.rich_text.map((t:any) => t.plain_text).join('');
                         return <li class="bullet-list">・ {text}</li>;
                    }
                    // 🌟 追加：画像ブロック
                    if (block.type === 'image') {
                        const imageUrl = block.image.type === 'external' ? block.image.external.url : block.image.file.url;
                        return <img src={imageUrl} alt="記事画像" class="post-image" loading="lazy" />;
                    }
                    // 🌟 追加：コールアウト（強調ボックス）
                    if (block.type === 'callout') {
                         const icon = block.callout.icon?.emoji || '💡';
                         const text = block.callout.rich_text.map((t:any) => t.plain_text).join('');
                         return <div class="callout-box"><span class="callout-icon">{icon}</span><p>{text}</p></div>;
                    }
                    // 🌟 追加：ブックマーク＆動画（YouTubeなど）
                    if (block.type === 'bookmark' || block.type === 'video') {
                        const url = block.bookmark?.url || block.video?.external?.url;
                        if(url && url.includes('youtube.com/watch?v=')){
                            // YouTubeのURLを埋め込み用(embed)に変換
                            const videoId = url.split('v=')[1].split('&')[0];
                            const embedUrl = `https://www.youtube.com/embed/${videoId}`;
                            return (
                                <div class="youtube-wrapper">
                                    <iframe src={embedUrl} title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
                                </div>
                            );
                        } else if (url) {
                            return <a href={url} target="_blank" class="bookmark-link">🔗 リンク: {url}</a>;
                        }
                    }
                    return null;
                })
            ) : (
                <p>本文がまだありません。</p>
            )}
        </div>
        
        <div class="back-link">
            <a href="/blog" class="btn-back">← ブログ一覧へ戻る</a>
        </div>
    </article>
</Layout>

<style>
    .single-post-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 50px 20px;
    }
    
    .post-header {
        border-bottom: 2px solid var(--color-accent);
        padding-bottom: 20px;
        margin-bottom: 40px;
    }
    .post-date {
        color: #777;
        font-weight: bold;
        margin-bottom: 10px;
    }
    .post-title {
        font-size: 2.5rem;
        color: var(--color-primary);
        line-height: 1.4;
    }

    /* Notion本文のスタイル */
    .post-content {
        font-size: 1.1rem;
        line-height: 1.8;
        color: var(--color-text);
    }
    .post-content p {
        margin-bottom: 1.5em;
    }
    .post-content a {
        color: var(--color-accent);
        text-decoration: underline;
    }
    .post-content h2 {
        font-size: 1.8rem;
        color: var(--color-primary);
        margin-top: 2.5em;
        margin-bottom: 1em;
        padding-left: 10px;
        border-left: 5px solid var(--color-accent);
    }
    .post-content h3 {
        font-size: 1.4rem;
        color: var(--color-text);
        margin-top: 2em;
        margin-bottom: 0.8em;
    }
    .bullet-list {
        margin-left: 1.5em;
        margin-bottom: 0.5em;
        list-style-type: none;
    }

    /* 画像と動画とコールアウトのスタイル */
    .post-image {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: 2em 0;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .youtube-wrapper {
        position: relative;
        padding-bottom: 56.25%; /* 16:9 の比率 */
        height: 0;
        margin: 2em 0;
        border-radius: 8px;
        overflow: hidden;
    }
    .youtube-wrapper iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }
    .callout-box {
        display: flex;
        background-color: var(--color-bg);
        padding: 20px;
        border-radius: 8px;
        margin: 2em 0;
        border-left: 4px solid var(--color-primary);
    }
    .callout-icon {
        font-size: 1.5rem;
        margin-right: 15px;
    }
    .callout-box p {
        margin-bottom: 0;
    }
    .bookmark-link {
        display: inline-block;
        background-color: #f5f5f5;
        padding: 10px 15px;
        border-radius: 5px;
        margin: 1em 0;
        word-break: break-all;
    }

    .back-link {
        margin-top: 60px;
        text-align: center;
    }
    .btn-back {
        display: inline-block;
        padding: 12px 30px;
        background-color: var(--color-bg);
        color: var(--color-primary);
        text-decoration: none;
        border-radius: 30px;
        font-weight: bold;
        transition: all 0.3s;
    }
    .btn-back:hover {
        background-color: var(--color-primary);
        color: white;
    }
</style>