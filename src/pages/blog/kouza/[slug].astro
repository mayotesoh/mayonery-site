---
import Layout from '../../layouts/Layout.astro';

// 1. TypeScriptに「講座データが入ってくるよ」と教える
interface Props {
  course: any;
}

// 1. 全講座のURLのリストを作る
export async function getStaticPaths() {
  const apiKey = import.meta.env.NOTION_API_KEY;
  const databaseId = import.meta.env.NOTION_DATABASE_ID;

  const response = await fetch(`https://api.notion.com/v1/databases/${databaseId}/query`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${apiKey}`,
      'Notion-Version': '2022-06-28',
      'Content-Type': 'application/json',
    },
  });
  const data = await response.json();
  const allPosts = data.results || [];

  // タグが「講座」のものだけを抽出
  const courses = allPosts.filter((post: any) => {
    const tags = post.properties['タグ']?.multi_select?.map((t: any) => t.name) || [];
    return tags.includes('講座');
  });

  return courses.map((course: any) => {
    const slug = course.properties['URLスラッグ']?.rich_text[0]?.plain_text || course.id;
    return {
      params: { slug: slug },
      props: { course: course },
    };
  });
}

// 2. データの受け取り
const { course } = Astro.props;

// courseが存在しない場合の安全策
if (!course) {
  return Astro.redirect('/404');
}

const title = course.properties['タイトル']?.title[0]?.plain_text || '無題';
const level = course.properties['レベル']?.select?.name || 'クラス未設定';
const price = course.properties['価格']?.rich_text[0]?.plain_text || '';
const isPro = level.includes('プロ');

// 3. NotionのAPIを叩いて「本文（ブロック）」を取得する
const apiKey = import.meta.env.NOTION_API_KEY;
const blocksResponse = await fetch(`https://api.notion.com/v1/blocks/${course.id}/children?page_size=100`, {
  headers: {
    'Authorization': `Bearer ${apiKey}`,
    'Notion-Version': '2022-06-28',
  },
});
const blocksData = await blocksResponse.json();
const blocks = blocksData.results || [];
