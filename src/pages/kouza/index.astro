---
import Layout from '../../layouts/Layout.astro';

// .envから鍵とIDを読み込む
const apiKey = import.meta.env.NOTION_API_KEY;
const kouzaDbId = import.meta.env.NOTION_KOUZA_ID;

// Notionの「講座データベース」から全データを取得
const response = await fetch(`https://api.notion.com/v1/databases/${kouzaDbId}/query`, {
  method: 'POST',
  headers: {
    'Authorization': `Bearer ${apiKey}`,
    'Notion-Version': '2022-06-28',
    'Content-Type': 'application/json',
  },
});

const data = await response.json();
const allPosts = data.results || [];

// 🌟 ブログと同じ安全な方法で「公開」のものだけを絞り込む
const kouzaList = allPosts.filter((post: any) => {
  const status = post.properties['ステータス']?.status?.name || post.properties['ステータス']?.select?.name || '';
  return status === '公開';
});
---

<Layout title="手相学講座 | マヨネリ">
  <div class="kouza-container">
    <h1 class="page-title">手相学学習プログラム</h1>
    <p class="page-desc">論理的・客観的に「自分のキャラクター設計」を読み解くスキルを身につけます。</p>
    
    <div class="kouza-grid">
      {kouzaList.map((item: any) => {
        const title = item.properties['タイトル']?.title[0]?.plain_text || '無題';
        const summary = item.properties['概要']?.rich_text[0]?.plain_text || '';
        const price = item.properties['価格']?.rich_text[0]?.plain_text || '';
        const levels = item.properties['レベル']?.multi_select || [];
        const slug = item.properties['URLスラッグ']?.rich_text[0]?.plain_text || item.id;
        
        return (
          <a href={`/kouza/${slug}`} class="kouza-card">
            <div class="level-tags">
              {levels.map((level: any) => (
                <span class="level-tag" style={{backgroundColor: level.color === 'default' ? '#eee' : `var(--color-${level.color}, #ddd)`}}>{level.name}</span>
              ))}
            </div>
            <h2 class="kouza-title">{title}</h2>
            <p class="kouza-summary">{summary}</p>
            <div class="kouza-footer">
              <span class="kouza-price">{price}</span>
              <span class="view-more">詳細を見る →</span>
            </div>
          </a>
        );
      })}
    </div>
    
    {kouzaList.length === 0 && (
      <p style="text-align:center; color:#888;">現在、公開中の講座はありません。</p>
    )}
  </div>
</Layout>

<style>
  .kouza-container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }
  .page-title { text-align: center; color: var(--color-primary); font-size: 2.2rem; margin-bottom: 10px; }
  .page-desc { text-align: center; color: #666; margin-bottom: 40px; }
  
  .kouza-grid { display: flex; flex-direction: column; gap: 20px; }
  .kouza-card { 
    background: white; border: 1px solid #e0e0e0; padding: 30px; border-radius: 12px;
    text-decoration: none; color: inherit; transition: all 0.3s ease;
    display: flex; flex-direction: column;
  }
  .kouza-card:hover { border-color: var(--color-primary); transform: translateY(-3px); box-shadow: 0 8px 15px rgba(0,0,0,0.05); }
  
  .level-tags { display: flex; gap: 8px; margin-bottom: 15px; }
  .level-tag { font-size: 0.8rem; padding: 4px 10px; border-radius: 20px; font-weight: bold; background: #eef2f5; color: #555; }
  
  .kouza-title { font-size: 1.5rem; margin: 0 0 15px 0; color: var(--color-text); }
  .kouza-summary { color: #555; line-height: 1.6; margin-bottom: 20px; flex-grow: 1; }
  
  .kouza-footer { display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed #eee; padding-top: 20px; }
  .kouza-price { font-size: 1.2rem; font-weight: bold; color: var(--color-text); }
  .view-more { color: var(--color-primary); font-weight: bold; }
</style>