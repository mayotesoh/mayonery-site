---
import Layout from '../layouts/Layout.astro';

const apiKey = import.meta.env.NOTION_API_KEY;
const quizDbId = import.meta.env.NOTION_QUIZ_ID;

const response = await fetch(`https://api.notion.com/v1/databases/${quizDbId}/query`, {
  method: 'POST',
  headers: {
    'Authorization': `Bearer ${apiKey}`,
    'Notion-Version': '2022-06-28',
    'Content-Type': 'application/json',
  },
});
const data = await response.json();
const questions = data.results || [];
---

<Layout title="手相クイズ | マヨネリ">
  <div class="quiz-container">
    <h1 class="page-title">手相クイズ</h1>
    <p class="page-desc">あなたの手相リテラシーをチェックしてみましょう！</p>
    
    {questions.length === 0 ? (
      <p style="text-align:center; color:#888;">現在、問題を作成中です。公開までもうしばらくお待ちください。</p>
    ) : (
      <div id="quiz-app">
        
        {/* 🌟 一旦すべての問題を「非表示（display:none）」の状態で裏側に作っておく */}
        {questions.map((q: any, index: number) => {
          const text = q.properties['問題文']?.title[0]?.plain_text || '問題がありません';
          const op1 = q.properties['選択肢1']?.rich_text[0]?.plain_text || '';
          const op2 = q.properties['選択肢2']?.rich_text[0]?.plain_text || '';
          const op3 = q.properties['選択肢3']?.rich_text[0]?.plain_text || '';
          const op4 = q.properties['選択肢4']?.rich_text[0]?.plain_text || '';
          
          const ansProp = q.properties['正解の番号'];
          const answer = ansProp?.rich_text?.[0]?.plain_text || ansProp?.select?.name || ansProp?.number?.toString() || '1';
          
          const explanation = q.properties['解説']?.rich_text[0]?.plain_text || '解説はありません。';

          return (
            <div class="question-card" style="display:none;">
              <div class="q-header">問題 <span class="current-q"></span> / <span class="total-q"></span></div>
              <h2 class="q-text">{text}</h2>
              
              <div class="options-grid">
                {op1 && <button class="option-btn" data-choice="1" data-answer={answer}><span class="choice-num">1</span> {op1}</button>}
                {op2 && <button class="option-btn" data-choice="2" data-answer={answer}><span class="choice-num">2</span> {op2}</button>}
                {op3 && <button class="option-btn" data-choice="3" data-answer={answer}><span class="choice-num">3</span> {op3}</button>}
                {op4 && <button class="option-btn" data-choice="4" data-answer={answer}><span class="choice-num">4</span> {op4}</button>}
              </div>

              <div class="explanation-area hidden">
                <div class="result-badge"></div>
                <div class="exp-box">
                  <h3 class="exp-title">【解説】</h3>
                  <p class="exp-text">{explanation}</p>
                </div>
                <button class="next-btn" data-next=""></button>
              </div>
            </div>
          );
        })}

        <div id="result-screen" class="hidden">
          <h2>お疲れ様でした！</h2>
          <p class="final-score">あなたの正解数</p>
          <div class="score-display">
            <span id="score-number">0</span><span class="score-total"> / <span id="final-total"></span></span>
          </div>
          <p id="score-message" class="score-message"></p>
          
          <div class="result-actions">
            <button onclick="window.location.reload();" class="retry-btn">別の問題に挑戦する</button>
            <a href="/kouza" class="learn-btn">講座で基礎から学ぶ</a>
          </div>
        </div>
      </div>
    )}
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. 裏側に隠しておいた全カードを取得
    const allCards = Array.from(document.querySelectorAll('.question-card')) as HTMLElement[];
    const quizApp = document.getElementById('quiz-app');
    const resultScreen = document.getElementById('result-screen');
    
    if (allCards.length === 0 || !quizApp || !resultScreen) return;

    // 2. 配列をランダムにシャッフルする魔法
    for (let i = allCards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [allCards[i], allCards[j]] = [allCards[j], allCards[i]];
    }

    // 3. 上から最大10問だけを抽出（Notionの問題が10問以下の場合は全部）
    const MAX_QUESTIONS = 10;
    const selectedCards = allCards.slice(0, MAX_QUESTIONS);
    const totalQuestions = selectedCards.length;

    // 4. 一旦すべてのカードを画面から完全に消し去る
    allCards.forEach(card => card.remove());

    // 5. 選ばれた10問だけを綺麗に書き直して配置する
    selectedCards.forEach((card, index) => {
      // インデックス番号をセット
      card.setAttribute('data-index', index.toString());
      
      // ヘッダーの文字をセット (例: 問題 1 / 10)
      const header = card.querySelector('.q-header');
      if (header) {
        header.innerHTML = `問題 <span class="current-q">${index + 1}</span> / ${totalQuestions}`;
      }
      
      // 次へボタンの設定
      const nextBtn = card.querySelector('.next-btn');
      if (nextBtn) {
        nextBtn.setAttribute('data-next', (index + 1).toString());
        nextBtn.textContent = (index + 1 === totalQuestions) ? '結果を見る →' : '次の問題へ →';
      }
      
      // 結果画面の手前にカードを挿入
      quizApp.insertBefore(card, resultScreen);
    });

    // 6. 抽出した1問目だけを表示する
    if (selectedCards.length > 0) {
      selectedCards[0].style.display = 'block';
    }
    
    // 結果画面の分母も設定しておく
    const finalTotalEl = document.getElementById('final-total');
    if (finalTotalEl) finalTotalEl.textContent = totalQuestions.toString();

    // ----------------------------------------------------
    // ここから下は、選ばれた問題に対するクリックイベントの設定
    // ----------------------------------------------------
    let currentScore = 0;

    document.querySelectorAll('.option-btn').forEach(button => {
      button.addEventListener('click', (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const card = btn.closest('.question-card') as HTMLElement;
        
        if (card.classList.contains('answered')) return;
        card.classList.add('answered');

        const selected = btn.getAttribute('data-choice');
        const correct = btn.getAttribute('data-answer');
        const expArea = card.querySelector('.explanation-area') as HTMLElement;
        const badge = card.querySelector('.result-badge') as HTMLElement;

        card.querySelectorAll('.option-btn').forEach(b => {
          if(b !== btn) (b as HTMLElement).style.opacity = '0.6';
        });

        if (selected === correct) {
          btn.classList.add('correct');
          badge.innerHTML = '<span class="icon correct-icon">⭕</span> 正解！';
          badge.className = 'result-badge correct-badge';
          currentScore++;
        } else {
          btn.classList.add('wrong');
          badge.innerHTML = '<span class="icon wrong-icon">❌</span> 不正解...';
          badge.className = 'result-badge wrong-badge';
          const correctBtn = card.querySelector(`.option-btn[data-choice="${correct}"]`);
          if (correctBtn) correctBtn.classList.add('correct');
        }

        expArea.classList.remove('hidden');
      });
    });

    document.querySelectorAll('.next-btn').forEach(button => {
      button.addEventListener('click', (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const nextIndex = parseInt(btn.getAttribute('data-next') || '0');
        const currentCard = btn.closest('.question-card') as HTMLElement;
        
        currentCard.style.display = 'none'; 
        
        const nextCard = document.querySelector(`.question-card[data-index="${nextIndex}"]`) as HTMLElement;
        if (nextCard) {
          nextCard.style.display = 'block'; 
        } else {
          resultScreen.classList.remove('hidden');
          const scoreNumber = document.getElementById('score-number');
          const scoreMessage = document.getElementById('score-message');
          
          if (scoreNumber && scoreMessage) {
            scoreNumber.textContent = currentScore.toString();
            const percentage = currentScore / totalQuestions;
            if (percentage === 1) {
              scoreMessage.textContent = '完璧です！素晴らしい手相リテラシーです！';
            } else if (percentage >= 0.5) {
              scoreMessage.textContent = '良いペースです！さらに理解を深めましょう！';
            } else {
              scoreMessage.textContent = '伸びしろがあります！用語集や講座を活用してみてくださいね。';
            }
          }
        }
      });
    });
  });
</script>

<style>
  .quiz-container { max-width: 650px; margin: 0 auto; padding: 40px 20px; }
  .page-title { text-align: center; color: var(--color-primary); font-size: 2rem; margin-bottom: 10px; }
  .page-desc { text-align: center; color: #666; margin-bottom: 40px; }
  
  .question-card { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); }
  .q-header { font-size: 1rem; color: var(--color-primary); margin-bottom: 15px; font-weight: bold; }
  .current-q, .total-q { font-size: 1.4rem; }
  .q-text { font-size: 1.3rem; margin-bottom: 25px; line-height: 1.5; color: var(--color-text); }
  
  .options-grid { display: flex; flex-direction: column; gap: 12px; }
  .option-btn { background: white; border: 2px solid #e0e0e0; padding: 15px 20px; border-radius: 8px; font-size: 1.05rem; text-align: left; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; color: var(--color-text); }
  .option-btn:hover { border-color: var(--color-primary); background: #f8fbf9; }
  .choice-num { display: inline-block; width: 24px; height: 24px; background: #eee; color: #555; text-align: center; border-radius: 50%; line-height: 24px; font-size: 0.9rem; margin-right: 15px; font-weight: bold; }
  
  .option-btn.correct { background: #e8f5e9; border-color: #4caf50; font-weight: bold; }
  .option-btn.correct .choice-num { background: #4caf50; color: white; }
  .option-btn.wrong { background: #ffebee; border-color: #f44336; }
  .option-btn.wrong .choice-num { background: #f44336; color: white; }
  
  .explanation-area { margin-top: 30px; animation: fadeIn 0.5s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
  
  .result-badge { font-size: 1.3rem; font-weight: bold; margin-bottom: 20px; padding: 15px; border-radius: 8px; text-align: center; }
  .correct-badge { background: #e8f5e9; color: #2e7d32; }
  .wrong-badge { background: #ffebee; color: #c62828; }
  .icon { margin-right: 8px; }
  
  .exp-box { background: #f9f9f9; padding: 20px; border-radius: 8px; border-left: 4px solid var(--color-primary); margin-bottom: 25px; }
  .exp-title { font-size: 1rem; color: var(--color-primary); margin: 0 0 10px 0; }
  .exp-text { line-height: 1.6; color: #444; margin: 0; white-space: pre-wrap; }
  
  .next-btn { display: block; width: 100%; padding: 16px; background: var(--color-primary); color: white; text-align: center; border: none; border-radius: 8px; font-size: 1.1rem; cursor: pointer; font-weight: bold; transition: opacity 0.2s; }
  .next-btn:hover { opacity: 0.9; }
  
  .hidden { display: none !important; }
  
  #result-screen { text-align: center; background: white; padding: 50px 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); }
  .final-score { font-size: 1.2rem; color: #666; margin-bottom: 10px; }
  .score-display { margin-bottom: 20px; }
  #score-number { font-size: 4rem; color: var(--color-primary); font-weight: bold; line-height: 1; }
  .score-total { font-size: 1.5rem; color: #888; }
  .score-message { font-size: 1.1rem; line-height: 1.5; color: var(--color-text); margin-bottom: 40px; }
  
  .result-actions { display: flex; flex-direction: column; gap: 15px; }
  .retry-btn, .learn-btn { display: block; padding: 15px; border-radius: 8px; font-size: 1.1rem; font-weight: bold; text-decoration: none; transition: opacity 0.2s; cursor: pointer; }
  .retry-btn { border: 2px solid var(--color-primary); color: var(--color-primary); background: white; }
  .learn-btn { background: var(--color-primary); color: white; }
  .retry-btn:hover, .learn-btn:hover { opacity: 0.8; }
</style>